@model ProductionOrderViewModel
@{
    ViewData["Title"] = "Werkstattaufträge";
    var today = DateTime.Today;
}

<h2 class="page-header">Werkstattaufträge</h2>

<div class="card filter-card mb-4">
    <div class="card-header">Filter</div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">WA Nummer</label>
                    <input type="text" name="filterOrderNumber" value="@Model.FilterOrderNumber" class="form-control" placeholder="WA Nummer" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Artikelnummer</label>
                    <input type="text" name="filterArticleNumber" value="@Model.FilterArticleNumber" class="form-control" placeholder="Artikelnummer" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Kunde</label>
                    <input type="text" name="filterCustomer" value="@Model.FilterCustomer" class="form-control" placeholder="Kunde" />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <div class="form-check mb-2">
                        <input type="checkbox" name="showDone" value="true" class="form-check-input" id="showDone"
                               @(Model.ShowDone ? "checked" : "") />
                        <label class="form-check-label" for="showDone">Erledigte anzeigen</label>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-secondary">Filtern</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Zurücksetzen</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped mb-0">
        <thead>
            <tr>
                <th>WA Nummer</th>
                <th class="text-end">Stückzahl</th>
                <th>Kunde</th>
                <th>Artikelnummer</th>
                <th>Bezeichnung 1</th>
                <th>Bezeichnung 2</th>
                <th>Fertigungstermin</th>
                <th>Liefertermin</th>
                <th title="Fertigungstermin - @Model.KommissionierTage Arbeitstage">Kommissionierung</th>
                <th title="Kommissioniertermin - @Model.VorkommissionierTage Arbeitstag(e)">Vorkommissionierung</th>
                <th title="Kommissioniertermin - @Model.BeschichtungTage Arbeitstage">Beschichtung</th>
                <th>Status</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="@(item.IsDone ? "table-secondary" : "")">
                    <td><strong>@item.OrderNumber</strong></td>
                    <td class="text-end">@item.Quantity.ToString("N3")</td>
                    <td>@item.Customer</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ArticleNumber))
                        {
                            <strong>@item.ArticleNumber</strong>
                            <a href="http://akevault24.ake.at/AutodeskTC/AKE-VAULT01/explore?search=@item.ArticleNumber&searchContext=0" target="_blank" title="Zeichnung in Vault öffnen" class="vault-link">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/>
                                    <path d="M4.5 12.5A.5.5 0 0 1 5 12h3a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-2A.5.5 0 0 1 5 10h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m1.639-3.708 1.33.886 1.854-1.855a.25.25 0 0 1 .289-.047l1.888.974V7.5a.5.5 0 0 1-.5.5H5a.5.5 0 0 1-.5-.5V7s1.54-1.274 1.639-1.208M6.25 6a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5"/>
                                </svg>
                            </a>
                        }
                    </td>
                    <td>@item.Description1</td>
                    <td>@item.Description2</td>
                    <td>@item.ProductionDate?.ToString("dd.MM.yyyy")</td>
                    <td>@item.DeliveryDate?.ToString("dd.MM.yyyy")</td>
                    <td class="@(!item.IsDone && item.KommissionierTermin.HasValue && item.KommissionierTermin.Value < today ? "text-danger fw-bold" : "")">
                        @item.KommissionierTermin?.ToString("dd.MM.yyyy")
                    </td>
                    <td class="@(!item.IsDone && item.VorkommissionierTermin.HasValue && item.VorkommissionierTermin.Value < today ? "text-danger fw-bold" : "")">
                        @item.VorkommissionierTermin?.ToString("dd.MM.yyyy")
                    </td>
                    <td class="@(!item.IsDone && item.BeschichtungTermin.HasValue && item.BeschichtungTermin.Value < today ? "text-danger fw-bold" : "")">
                        @item.BeschichtungTermin?.ToString("dd.MM.yyyy")
                    </td>
                    <td>
                        @if (item.IsDone)
                        {
                            <span class="badge bg-secondary">Erledigt</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Offen</span>
                        }
                    </td>
                    <td>
                        <form asp-action="ToggleDone" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn btn-sm @(item.IsDone ? "btn-outline-success" : "btn-outline-secondary")"
                                    title="@(item.IsDone ? "Als offen markieren" : "Als erledigt markieren")">
                                @if (item.IsDone)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                    </svg>
                                }
                                else
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/>
                                        <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                    </svg>
                                }
                            </button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="13" class="text-center text-muted py-4">Keine Werkstattaufträge gefunden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3 text-muted">
    <small>@Model.Items.Count Einträge</small>
</div>
