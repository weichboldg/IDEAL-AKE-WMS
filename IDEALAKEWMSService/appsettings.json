{
  "ConnectionStrings": {
    "DefaultConnection": "Server=AKESQL20.ake.at;Database=IDEAL_AKE_WMS;Trusted_Connection=True;TrustServerCertificate=True;",
    "SageConnection": "Server=AKESQL20.ake.at;Database=ake;Trusted_Connection=True;TrustServerCertificate=True;",
    "OseonConnection": "Server=aketrumpf01.ake.at\\TRUMPFSQL2;Database=T1000_V01_V001;Trusted_Connection=True;TrustServerCertificate=True",
    "EnaioDmsConnection": "Server=AKESQL20.ake.at;Database=enaio;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "MailSettings": {
    "SmtpHost": "",
    "SmtpPort": 25,
    "SmtpUseSsl": false,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "SenderName": "IDEAL AKE WMS",
    "FromAddress": "wms@ake.at"
  },
  "Sync": {
    "ProductionOrdersEnabled": true,
    "ArticlesEnabled": true,
    "OseonTrackingEnabled": false,
    "EnaioDmsEnabled": false,
    "OseonArticleCategoryEnabled": false,
    "PartRequisitionEmailEnabled": false
  },
  "WorkerSettings": {
    "SyncIntervalMinutes": 15,
    "NotificationCheckIntervalMinutes": 60,
    "SyncDryRun": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": { "expression": "SourceContext like '%SyncWorker%' or SourceContext like '%SageImportService%' or SourceContext like '%OseonSyncService%' or SourceContext like '%EnaioDmsSyncService%'" }
              }
            ],
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "logs/sync/sync-.log",
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 30,
                  "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
              }
            ]
          }
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": { "expression": "SourceContext like '%NotificationWorker%' or SourceContext like '%StockCheckService%' or SourceContext like '%MailService%'" }
              }
            ],
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "logs/notifications/notifications-.log",
                  "rollingInterval": "Day",
                  "retainedFileCountLimit": 30,
                  "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
              }
            ]
          }
        }
      }
    ]
  }
}
