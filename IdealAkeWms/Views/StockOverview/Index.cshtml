@model StockOverviewViewModel
@{
    ViewData["Title"] = "Artikelbestände";
}

<h2 class="page-header">Artikelbestände</h2>

<div class="card filter-card mb-4">
    <div class="card-header">Filter</div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Artikel</label>
                    <div class="input-group">
                        <input type="text" name="filterArticle" id="filterArticle" value="@Model.FilterArticle" class="form-control" placeholder="Artikelnr. oder Bezeichnung" />
                        <button type="button" class="btn btn-outline-secondary" id="btnScanArticleFilter" title="Artikel-QR-Code scannen"
                                data-qr-fa-enabled="true" data-fa-target="filterProductionOrder">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M1.5 1a.5.5 0 0 0-.5.5v3a.5.5 0 0 1-1 0v-3A1.5 1.5 0 0 1 1.5 0h3a.5.5 0 0 1 0 1zM11 .5a.5.5 0 0 1 .5-.5h3A1.5 1.5 0 0 1 16 1.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 1-.5-.5M.5 11a.5.5 0 0 1 .5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 1 0 1h-3A1.5 1.5 0 0 1 0 14.5v-3a.5.5 0 0 1 .5-.5m15 0a.5.5 0 0 1 .5.5v3a1.5 1.5 0 0 1-1.5 1.5h-3a.5.5 0 0 1 0-1h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 1 .5-.5M3 4.5a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Lagerplatz</label>
                    <div class="input-group">
                        <select name="filterStorageLocationId" id="filterStorageLocationId" class="form-select">
                            <option value="">-- Alle --</option>
                            @foreach (var sl in Model.StorageLocations)
                            {
                                <option value="@sl.Id" selected="@(Model.FilterStorageLocationId == sl.Id)">@sl.Code</option>
                            }
                        </select>
                        <button type="button" class="btn btn-outline-secondary" id="btnScanLocationFilter" title="Lagerplatz scannen">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M1.5 1a.5.5 0 0 0-.5.5v3a.5.5 0 0 1-1 0v-3A1.5 1.5 0 0 1 1.5 0h3a.5.5 0 0 1 0 1zM11 .5a.5.5 0 0 1 .5-.5h3A1.5 1.5 0 0 1 16 1.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 1-.5-.5M.5 11a.5.5 0 0 1 .5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 1 0 1h-3A1.5 1.5 0 0 1 0 14.5v-3a.5.5 0 0 1 .5-.5m15 0a.5.5 0 0 1 .5.5v3a1.5 1.5 0 0 1-1.5 1.5h-3a.5.5 0 0 1 0-1h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 1 .5-.5M3 4.5a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fertigungsauftrag</label>
                    <div class="input-group">
                        <input type="text" name="filterProductionOrder" id="filterProductionOrder" value="@Model.FilterProductionOrder" class="form-control" placeholder="FA-Nr." />
                        <button type="button" class="btn btn-outline-secondary" id="btnScanPO" title="FA-QR-Code scannen">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M1.5 1a.5.5 0 0 0-.5.5v3a.5.5 0 0 1-1 0v-3A1.5 1.5 0 0 1 1.5 0h3a.5.5 0 0 1 0 1zM11 .5a.5.5 0 0 1 .5-.5h3A1.5 1.5 0 0 1 16 1.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 1-.5-.5M.5 11a.5.5 0 0 1 .5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 1 0 1h-3A1.5 1.5 0 0 1 0 14.5v-3a.5.5 0 0 1 .5-.5m15 0a.5.5 0 0 1 .5.5v3a1.5 1.5 0 0 1-1.5 1.5h-3a.5.5 0 0 1 0-1h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 1 .5-.5M3 4.5a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Bestand min.</label>
                    <input type="number" name="filterMinQuantity" value="@Model.FilterMinQuantity" class="form-control" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Bestand max.</label>
                    <input type="number" name="filterMaxQuantity" value="@Model.FilterMaxQuantity" class="form-control" step="0.01" />
                </div>
                <div class="col-md-2 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-secondary">Filtern</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Zurücksetzen</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table">
        <thead>
            <tr>
                <th data-filterable data-col-key="article-number">Artikelnummer</th>
                <th data-filterable data-col-key="description">Bezeichnung</th>
                <th data-filterable data-col-key="storage-location">Lagerplatz</th>
                <th data-filterable data-col-key="unit">Einheit</th>
                <th class="text-end" data-filterable data-col-key="reorder-level">Meldebestand</th>
                <th class="text-end" data-filterable data-col-key="current-stock">Aktueller Bestand</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                var qtyClass = "qty-positive";
                if (item.CurrentQuantity == 0)
                {
                    qtyClass = "qty-zero";
                }
                else if (item.CurrentQuantity < 0)
                {
                    qtyClass = "qty-negative";
                }

                // Color coding based on reorder level thresholds (nicht fuer Kommissionierwagen)
                var stockColorClass = "";
                if (item.ReorderLevel.HasValue && item.ReorderLevel.Value > 0m && !item.IsPickingTransport)
                {
                    var warningLevel = item.ReorderLevel.Value * Model.WarningThresholdPercent / 100m;
                    var criticalLevel = item.ReorderLevel.Value * Model.CriticalThresholdPercent / 100m;
                    if (item.CurrentQuantity <= criticalLevel)
                    {
                        stockColorClass = "stock-critical";
                    }
                    else if (item.CurrentQuantity <= warningLevel)
                    {
                        stockColorClass = "stock-warning";
                    }
                }
                <tr>
                    <td>
                        <strong>@item.ArticleNumber</strong>
                        <a href="http://akevault24.ake.at/AutodeskTC/AKE-VAULT01/explore?search=@item.ArticleNumber&searchContext=0" target="_blank" title="Zeichnung in Vault öffnen" class="vault-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/>
                                <path d="M4.5 12.5A.5.5 0 0 1 5 12h3a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-2A.5.5 0 0 1 5 10h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m1.639-3.708 1.33.886 1.854-1.855a.25.25 0 0 1 .289-.047l1.888.974V7.5a.5.5 0 0 1-.5.5H5a.5.5 0 0 1-.5-.5V7s1.54-1.274 1.639-1.208M6.25 6a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5"/>
                            </svg>
                        </a>
                    </td>
                    <td>@item.ArticleDescription</td>
                    <td>
                        <strong>@item.StorageLocationCode</strong>
                        @if (!item.StorageLocationIsActive && item.CurrentQuantity > 0)
                        {
                            <span class="badge bg-warning text-dark ms-1" title="Lagerplatz ist deaktiviert (Sage), Bestand sollte umgebucht werden">inaktiv</span>
                        }
                        @if (!string.IsNullOrEmpty(item.StorageLocationDescription))
                        {
                            <br /><small class="text-muted">@item.StorageLocationDescription</small>
                        }
                    </td>
                    <td>@item.Unit</td>
                    <td class="text-end">@(item.ReorderLevel.HasValue ? item.ReorderLevel.Value.ToString("N3") : "–")</td>
                    <td class="text-end @qtyClass @stockColorClass">@item.CurrentQuantity.ToString("N3")</td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">Keine Bestände gefunden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3 text-muted">
    <small>@Model.Items.Count Einträge</small>
</div>

@section Scripts {
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script src="~/js/barcode-scanner.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initScanner('btnScanLocationFilter', 'filterStorageLocationId', 'storageLocation');
            initScanner('btnScanArticleFilter', 'filterArticle', 'article');
            initScanner('btnScanPO', 'filterProductionOrder', 'productionOrder');
            document.getElementById('filterStorageLocationId').addEventListener('change', function () {
                this.closest('form').submit();
            });
        });
    </script>
}
