@model List<StorageLocation>
@{
    ViewData["Title"] = "Lagerplätze";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Lagerplätze</h2>
    <div class="d-flex gap-2">
        <a asp-action="PrintLabels" class="btn btn-secondary">Alle Etiketten drucken</a>
        <a asp-action="Create" class="btn btn-primary">Neuen Lagerplatz anlegen</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table">
        <thead>
            <tr>
                <th data-filterable data-col-key="code">Code</th>
                <th data-filterable data-col-key="description">Bezeichnung</th>
                <th data-filterable data-col-key="zone">Bereich/Zone</th>
                <th data-filterable data-col-key="capacity">Kapazität</th>
                <th data-filterable data-col-key="type">Typ</th>
                <th data-filterable data-col-key="created-at">Erstellt am</th>
                <th style="width: 100px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var location in Model)
            {
                <tr>
                    <td><strong>@location.Code</strong></td>
                    <td>@location.Description</td>
                    <td>@location.Zone</td>
                    <td>@location.Capacity?.ToString("N2")</td>
                    <td>@if (location.IsPickingTransport) { <span class="badge bg-info">Wagen</span> }</td>
                    <td>@location.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-nowrap">
                        <a asp-action="PrintLabel" asp-route-id="@location.Id" class="btn btn-sm btn-outline-secondary" title="Etikett drucken">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.5 8a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1"/>
                                <path d="M5 1a2 2 0 0 0-2 2v2H2a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1v1a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-1V3a2 2 0 0 0-2-2zM4 3a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2H4zm1 10a1 1 0 0 1-1-1v-2h8v2a1 1 0 0 1-1 1z"/>
                            </svg>
                        </a>
                        <a asp-action="Edit" asp-route-id="@location.Id" class="btn btn-sm btn-secondary">Bearbeiten</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Keine Lagerplätze vorhanden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
}
