@model StorageLocation
@{
    ViewData["Title"] = "Lagerplatz bearbeiten";
    var isSage = Model.Source == IdealAkeWms.Models.StorageLocationSource.Sage;
}

<h2 class="page-header">Lagerplatz bearbeiten</h2>

<div class="row">
    <div class="col-md-6">
        @if (isSage)
        {
            <div class="alert alert-info">
                Dieser Lagerplatz wird aus Sage synchronisiert. <strong>Code</strong>, <strong>Bereich/Zone</strong>, <strong>Bezeichnung</strong> und <strong>Aktiv</strong> sind gesperrt &mdash; sie werden beim n&auml;chsten Abgleich aus Sage uebernommen.
            </div>
        }
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="CreatedBy" />
                    <input type="hidden" asp-for="CreatedByWindows" />
                    <input type="hidden" asp-for="Source" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Code" class="form-label"></label>
                        @if (isSage)
                        {
                            <input asp-for="Code" class="form-control bg-light" maxlength="12" readonly />
                        }
                        else
                        {
                            <input asp-for="Code" class="form-control" maxlength="12" autofocus />
                        }
                        <div class="form-text">Maximal 12 Zeichen (für Barcode-Lesbarkeit).</div>
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        @if (isSage)
                        {
                            <input asp-for="Description" class="form-control bg-light" readonly />
                        }
                        else
                        {
                            <input asp-for="Description" class="form-control" />
                        }
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Zone" class="form-label"></label>
                        @if (isSage)
                        {
                            <input asp-for="Zone" class="form-control bg-light" readonly />
                        }
                        else
                        {
                            <input asp-for="Zone" class="form-control" />
                        }
                        <span asp-validation-for="Zone" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label"></label>
                        <input asp-for="Capacity" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check form-switch">
                        @if (isSage)
                        {
                            <input type="hidden" asp-for="IsActive" />
                            <input class="form-check-input" type="checkbox" disabled @(Model.IsActive ? "checked" : "") />
                            <label asp-for="IsActive" class="form-check-label"></label>
                            <div class="form-text">Wird aus Sage synchronisiert.</div>
                        }
                        else
                        {
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                        }
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IstBuchbar" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IstBuchbar" class="form-check-label">F&uuml;r Buchungen freigegeben</label>
                        </div>
                        <small class="form-text text-muted">
                            Wenn deaktiviert, ist der Lagerplatz in Buchungs-Dropdowns
                            (Einbuchung/Ausbuchung/Umbuchung/Picking) nicht ausw&auml;hlbar.
                            Bestand auf nicht-buchbaren Pl&auml;tzen wird in der Bestands&uuml;bersicht weiterhin angezeigt.
                        </small>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsPickingTransport" class="form-check-input" />
                        <label asp-for="IsPickingTransport" class="form-check-label"></label>
                        <div class="form-text">Aktiviert Konfliktprüfung beim Umbuchen (verschiedene FA auf gleichem Wagen).</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Speichern</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
