@model PickingLeitstandViewModel
@using System.Globalization
@{
    var pageTitle = "Fertigungsaufträge";
    ViewData["Title"] = pageTitle;
    var today = DateTime.Today;
    // ISO 8601 Kalenderwoche berechnen
    string FormatDateWithKw(DateTime? date)
    {
        if (!date.HasValue) return "";
        var d = date.Value;
        var kw = ISOWeek.GetWeekOfYear(d);
        return $"{d:dd.MM.yyyy} KW{kw}";
    }
}

<h2 class="page-header">@pageTitle</h2>

<div class="card filter-card mb-4">
    <div class="card-header">Filter</div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">FA Nummer</label>
                    <div class="input-group">
                        <input type="text" id="filterOrderNumber" name="filterOrderNumber" value="@Model.FilterOrderNumber" class="form-control" placeholder="FA Nummer" />
                        <button type="button" id="btnScanOrderNumber" class="btn btn-outline-secondary" title="QR-Code scannen">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M1.5 1a.5.5 0 0 0-.5.5v3a.5.5 0 0 1-1 0v-3A1.5 1.5 0 0 1 1.5 0h3a.5.5 0 0 1 0 1zM11 .5a.5.5 0 0 1 .5-.5h3A1.5 1.5 0 0 1 16 1.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 1-.5-.5M.5 11a.5.5 0 0 1 .5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 1 0 1h-3A1.5 1.5 0 0 1 0 14.5v-3a.5.5 0 0 1 .5-.5m15 0a.5.5 0 0 1 .5.5v3a1.5 1.5 0 0 1-1.5 1.5h-3a.5.5 0 0 1 0-1h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 1 .5-.5M3 4.5a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Artikelnummer</label>
                    <div class="input-group">
                        <input type="text" id="filterArticleNumber" name="filterArticleNumber" value="@Model.FilterArticleNumber" class="form-control" placeholder="Artikelnummer" />
                        <button type="button" id="btnScanArticleNumber" class="btn btn-outline-secondary" title="QR-Code scannen">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M1.5 1a.5.5 0 0 0-.5.5v3a.5.5 0 0 1-1 0v-3A1.5 1.5 0 0 1 1.5 0h3a.5.5 0 0 1 0 1zM11 .5a.5.5 0 0 1 .5-.5h3A1.5 1.5 0 0 1 16 1.5v3a.5.5 0 0 1-1 0v-3a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 1-.5-.5M.5 11a.5.5 0 0 1 .5.5v3a.5.5 0 0 0 .5.5h3a.5.5 0 0 1 0 1h-3A1.5 1.5 0 0 1 0 14.5v-3a.5.5 0 0 1 .5-.5m15 0a.5.5 0 0 1 .5.5v3a1.5 1.5 0 0 1-1.5 1.5h-3a.5.5 0 0 1 0-1h3a.5.5 0 0 0 .5-.5v-3a.5.5 0 0 1 .5-.5M3 4.5a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0zm2 0a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5zm3 0a.5.5 0 0 1 1 0v7a.5.5 0 0 1-1 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Kunde</label>
                    <input type="text" name="filterCustomer" value="@Model.FilterCustomer" class="form-control" placeholder="Kunde" />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <div class="form-check mb-2">
                        <input type="checkbox" name="showDone" value="true" class="form-check-input" id="showDone"
                               @(Model.ShowDone ? "checked" : "") />
                        <label class="form-check-label" for="showDone">Erledigte anzeigen</label>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-secondary">Filtern</button>
                    <a asp-action="Index" class="btn btn-outline-secondary" data-clear-table-filters="PickingLeitstand">Zurücksetzen</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
{
    <div id="bulkActionBar" class="bulk-action-bar" style="display:none;">
        <span class="me-3"><strong id="bulkSelectedCount">0</strong> markiert</span>
        <form asp-controller="PickingLeitstand" asp-action="BulkRelease" method="post" id="bulkReleaseForm" class="d-inline me-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="release" value="true" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <button type="submit" id="btnBulkRelease" class="btn btn-sm btn-outline-secondary" disabled>
                Markierte freigeben
            </button>
        </form>
        <form asp-controller="PickingLeitstand" asp-action="BulkRelease" method="post" id="bulkUnreleaseForm" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="release" value="false" />
            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
            <button type="submit" id="btnBulkUnrelease" class="btn btn-sm btn-outline-success" disabled>
                Markierte zurücknehmen
            </button>
        </form>
    </div>
}

@* Toolbar host fuer column-preferences-Gear-Button (sonst landet er im versteckten bulkActionBar) *@
<div class="d-flex justify-content-end mb-1"></div>

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table" data-view-key="PickingLeitstand" data-fallback-sort-column="picking-date" data-fallback-sort-direction="asc" data-server-column-filter="true">
        <thead>
            <tr>
                @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
                {
                    <th style="width: 32px;" class="bulk-checkbox-col" data-col-key="bulk-select">
                        <input type="checkbox" id="bulkSelectAll" title="Alle sichtbaren auswählen" />
                    </th>
                }
                @if (Model.CanPick)
                {
                    <th style="width: 40px;" data-col-key="actions"></th>
                }
                <th style="width: 90px;" data-filterable data-col-key="order-number">FA Nr.</th>
                <th class="text-end" style="width: 55px;" data-col-key="quantity">Stk.</th>
                <th data-filterable data-col-key="customer">Kunde</th>
                <th data-filterable data-col-key="article-number">Artikelnummer</th>
                <th data-filterable data-col-key="description1">Bezeichnung 1</th>
                <th data-filterable data-col-key="description2">Bezeichnung 2</th>
                <th data-filterable data-col-key="workbench">Werkbank</th>
                <th class="text-nowrap" data-filterable data-col-key="coating-date" data-date-filter title="Kommissioniertermin - @Model.BeschichtungTage Arbeitstage">Beschicht.</th>
                <th class="text-nowrap" data-filterable data-col-key="bg-date" data-date-filter title="Kommissioniertermin - @Model.VorkommissionierTage Arbeitstag(e)">BG-Termin</th>
                <th class="text-nowrap" data-filterable data-col-key="picking-date" data-date-filter title="Fertigungstermin - @Model.KommissionierTage Arbeitstage">Komm.</th>
                <th class="text-nowrap" data-filterable data-col-key="production-date" data-date-filter>Fert.-Termin</th>
                <th class="text-nowrap" data-filterable data-col-key="delivery-date" data-date-filter>Liefertermin</th>
                <th class="text-nowrap text-center" style="width: 55px;" data-col-key="coating-part">Lack-T</th>
                <th style="width: 45px;" data-filterable data-col-key="glass">Glas</th>
                <th style="width: 55px;" data-filterable data-col-key="purchase">Zukauf</th>
                <th style="width: 40px;" data-filterable data-col-key="cooling"        title="VK Kälte">VK</th>
                <th style="width: 40px;" data-filterable data-col-key="fan"            title="VL Lüfter">VL</th>
                <th style="width: 40px;" data-filterable data-col-key="electric"       title="VE Elektro">VE</th>
                <th style="width: 40px;" data-filterable data-col-key="doors"          title="VT Türen">VT</th>
                <th style="width: 40px;" data-filterable data-col-key="superstructure" title="VA Aufbau">VA</th>
                <th data-filterable data-col-key="status">Status</th>
                <th style="width: 80px;" data-col-key="row-actions"></th>
                @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
                {
                    <th style="width: 160px;" data-col-key="release">Freigabe</th>
                }
                @if (Model.PickerAssignmentEnabled)
                {
                    <th data-filterable data-col-key="picker">Kommissionierer</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="@(item.IsDone ? "table-secondary" : "")">
                    @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
                    {
                        <td class="bulk-checkbox-col">
                            @if (!item.IsDone)
                            {
                                <input type="checkbox" class="bulk-row-checkbox"
                                       data-id="@item.Id"
                                       data-released="@(item.IsReleasedForPicking ? "true" : "false")"
                                       data-has-article="@(string.IsNullOrEmpty(item.ArticleNumber) ? "false" : "true")" />
                            }
                        </td>
                    }
                    @if (Model.CanPick)
                    {
                        <td class="text-nowrap">
                            @if (!string.IsNullOrEmpty(item.ArticleNumber))
                            {
                                <a asp-controller="Picking" asp-action="Bom" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Stückliste">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6zm1.5.5A.5.5 0 0 1 1 13V6a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5z"/>
                                    </svg>
                                </a>
                            }
                        </td>
                    }
                    <td>
                        <strong>@item.OrderNumber</strong>
                        @if (Model.EnaioDmsLinks.TryGetValue(item.OrderNumber, out var dmsLinks))
                        {
                            foreach (var dms in dmsLinks)
                            {
                                var dmsUrl = $"http://akeosapp.ake.at/oscontentviewer/viewer/{dms.EnaioDmsObjectId}/?pagecount=1";
                                var dmsTitle = dms.DocumentType == "Zeichnung" ? "Zeichnung in enaio oeffnen" : "Dokument in enaio oeffnen";
                                if (dms.DocumentType == "Zeichnung")
                                {
                                    <a href="@dmsUrl" target="_blank" title="@dmsTitle" class="dms-link"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M4.502 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/><path d="M14.002 13a2 2 0 0 1-2 2h-10a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10zM14 2H2a1 1 0 0 0-1 1v6.5l2.7-2.7a.5.5 0 0 1 .6-.1L9 10l2.6-2.6a.5.5 0 0 1 .7 0L15 10V3a1 1 0 0 0-1-1"/></svg></a>
                                }
                                else
                                {
                                    <a href="@dmsUrl" target="_blank" title="@dmsTitle" class="dms-link"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/></svg></a>
                                }
                            }
                        }
                    </td>
                    <td class="text-end">@item.Quantity.ToString("N3")</td>
                    <td>@item.Customer</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ArticleNumber))
                        {
                            <strong>@item.ArticleNumber</strong>
                            <a href="http://akevault24.ake.at/AutodeskTC/AKE-VAULT01/explore?search=@item.ArticleNumber&searchContext=0" target="_blank" title="Zeichnung in Vault öffnen" class="vault-link">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/>
                                    <path d="M4.5 12.5A.5.5 0 0 1 5 12h3a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-2A.5.5 0 0 1 5 10h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m1.639-3.708 1.33.886 1.854-1.855a.25.25 0 0 1 .289-.047l1.888.974V7.5a.5.5 0 0 1-.5.5H5a.5.5 0 0 1-.5-.5V7s1.54-1.274 1.639-1.208M6.25 6a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5"/>
                                </svg>
                            </a>
                        }
                    </td>
                    <td>@item.Description1</td>
                    <td>@item.Description2</td>
                    <td>@item.WorkplaceName</td>
                    @{
                        var lackName = ViewBag.LackierteilKategorieName as string;
                        var featureInactive = string.IsNullOrWhiteSpace(lackName);
                        var showBeschicht = featureInactive || item.HasCoatingParts;
                        var beschichtRed = showBeschicht
                                           && !item.IsDone
                                           && !item.IsCoatingDone
                                           && item.BeschichtungTermin.HasValue
                                           && item.BeschichtungTermin.Value < today;
                    }
                    <td class="@(beschichtRed ? "text-danger fw-bold" : "")">
                        @(showBeschicht ? FormatDateWithKw(item.BeschichtungTermin) : "")
                    </td>
                    <td class="@(!item.IsDone && item.VorkommissionierTermin.HasValue && item.VorkommissionierTermin.Value < today ? "text-danger fw-bold" : "")">
                        @FormatDateWithKw(item.VorkommissionierTermin)
                    </td>
                    <td class="@(!item.IsDone && item.KommissionierTermin.HasValue && item.KommissionierTermin.Value < today ? "text-danger fw-bold" : "kommissionier-date")">
                        @FormatDateWithKw(item.KommissionierTermin)
                    </td>
                    <td>@FormatDateWithKw(item.ProductionDate)</td>
                    <td>@FormatDateWithKw(item.DeliveryDate)</td>
                    <td class="text-center">
                        @if (item.HasCoatingParts)
                        {
                            <input type="checkbox" class="form-check-input toggle-field"
                                   data-id="@item.Id"
                                   data-endpoint="/api/picking-status/toggle"
                                   data-field="IsCoatingDone"
                                   title="Lackierteile erledigt"
                                   @(item.IsCoatingDone ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                        }
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field"
                               data-id="@item.Id"
                               data-endpoint="/api/picking-status/toggle"
                               data-field="HasGlass"
                               @(item.HasGlass ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field"
                               data-id="@item.Id"
                               data-endpoint="/api/picking-status/toggle"
                               data-field="HasExternalPurchase"
                               @(item.HasExternalPurchase ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field"
                               data-id="@item.Id"
                               data-endpoint="/api/assembly-groups/toggle-applicable"
                               data-group-key="VK"
                               title="VK Kälte" @(item.HasCooling ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field"
                               data-id="@item.Id"
                               data-endpoint="/api/assembly-groups/toggle-applicable"
                               data-group-key="VL"
                               title="VL Lüfter" @(item.HasFan ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field"
                               data-id="@item.Id"
                               data-endpoint="/api/assembly-groups/toggle-applicable"
                               data-group-key="VE"
                               title="VE Elektro" @(item.HasElectric ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field"
                               data-id="@item.Id"
                               data-endpoint="/api/assembly-groups/toggle-applicable"
                               data-group-key="VT"
                               title="VT Türen" @(item.HasDoors ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field"
                               data-id="@item.Id"
                               data-endpoint="/api/assembly-groups/toggle-applicable"
                               data-group-key="VA"
                               title="VA Aufbau" @(item.HasSuperstructure ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td>
                        @if (item.IsDone)
                        {
                            <span class="badge bg-secondary">Erledigt</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Offen</span>
                        }
                        @if (!string.IsNullOrEmpty(item.PickingStatus))
                        {
                            if (item.PickingStatus == "abgeschlossen")
                            {
                                <span class="badge badge-picking-done ms-1">Komm.</span>
                            }
                            else if (item.PickingStatus == "teilkommissioniert")
                            {
                                <span class="badge badge-picking-partial ms-1">Teilkomm.</span>
                            }
                        }
                    </td>
                    <td class="text-nowrap">
                        <a asp-controller="Tracking" asp-action="OseonIndex" asp-route-filterCustomerOrder="@item.OrderNumber" asp-route-showFinished="true"
                           class="btn btn-sm btn-outline-info me-1" title="OSEON Teileverfolgung">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.399l-.451.004.09-.41h2.281z"/>
                                <path d="M8 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2"/>
                            </svg>
                        </a>
                        @if (Model.CanPick)
                        {
                            <form asp-controller="Picking" asp-action="ToggleDone" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-sm @(item.IsDone ? "btn-outline-success" : "btn-outline-secondary")"
                                        title="@(item.IsDone ? "Als offen markieren" : "Als erledigt markieren")">
                                    @if (item.IsDone)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/>
                                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                        </svg>
                                    }
                                </button>
                            </form>
                        }
                    </td>
                    @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
                    {
                        <td class="text-center text-nowrap">
                            @if (!item.IsDone)
                            {
                                <form asp-controller="PickingLeitstand" asp-action="ToggleRelease" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    @if (item.IsReleasedForPicking)
                                    {
                                        <button type="submit" class="btn btn-sm btn-success me-1" title="Freigabe zurücknehmen">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/>
                                            </svg>
                                        </button>
                                    }
                                    else if (!string.IsNullOrEmpty(item.ArticleNumber))
                                    {
                                        @if (Model.PickerAssignmentEnabled)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary open-release-modal"
                                                    data-order-id="@item.Id" title="Zur Kommissionierung freigeben">
                                                Freigeben
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Zur Kommissionierung freigeben">
                                                Freigeben
                                            </button>
                                        }
                                    }
                                </form>
                                @if (item.IsReleasedForPicking)
                                {
                                    <input type="number" class="form-control form-control-sm d-inline-block priority-input"
                                           value="@item.PickingPriority" min="1" style="width:55px"
                                           data-id="@item.Id" title="Priorität (1 = höchste)" />
                                }
                            }
                        </td>
                    }
                    @if (Model.PickerAssignmentEnabled)
                    {
                        <td>
                            @if (item.IsReleasedForPicking && !string.IsNullOrEmpty(item.AssignedPickerName))
                            {
                                <a href="#" class="change-picker-link" data-order-id="@item.Id" data-picker-name="@item.AssignedPickerName"
                                   title="Kommissionierer aendern">@item.AssignedPickerName</a>
                            }
                        </td>
                    }
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    @{
                        // Rich-View Spalten ohne Conditionals = 22:
                        // order-number, quantity, customer, article-number, description1, description2,
                        // workbench, coating-date, bg-date, picking-date, production-date, delivery-date,
                        // coating-part, glass, purchase, cooling, fan, electric, doors, superstructure,
                        // status, row-actions
                        var colCount = 22;
                        if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
                        {
                            colCount++; // bulk-select
                            colCount++; // release
                        }
                        if (Model.CanPick) colCount++;                  // actions
                        if (Model.PickerAssignmentEnabled) colCount++;  // picker
                    }
                    <td colspan="@colCount" class="text-center text-muted py-4">Keine @pageTitle gefunden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<partial name="_Pagination" model="Model.Pagination" />

@if (Model.PickerAssignmentEnabled)
{
    var activePickers = ViewBag.ActivePickers as List<IdealAkeWms.Models.User> ?? new List<IdealAkeWms.Models.User>();

    <!-- Release Modal -->
    <div class="modal fade" id="releaseModal" tabindex="-1" aria-labelledby="releaseModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form asp-controller="PickingLeitstand" asp-action="ToggleRelease" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="releaseModalOrderId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <div class="modal-header">
                        <h5 class="modal-title" id="releaseModalLabel">Kommissionier-Freigabe</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schliessen"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="assignedPickerIdSelect" class="form-label">Kommissionierer zuweisen</label>
                            <select name="assignedPickerId" id="assignedPickerIdSelect" class="form-select" required>
                                <option value="">— Bitte auswaehlen —</option>
                                @foreach (var picker in activePickers)
                                {
                                    <option value="@picker.Id">@picker.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Abbrechen</button>
                        <button type="submit" class="btn btn-primary" id="releaseModalSubmit" disabled>Freigeben</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Change Picker Modal -->
    <div class="modal fade" id="changePickerModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Kommissionierer aendern</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schliessen"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="changePickerSelect" class="form-label">Neuer Kommissionierer</label>
                        <select id="changePickerSelect" class="form-select">
                            <option value="">— Bitte auswaehlen —</option>
                            @foreach (var picker in activePickers)
                            {
                                <option value="@picker.Id">@picker.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="button" class="btn btn-primary" id="changePickerSubmit" disabled>Speichern</button>
                </div>
            </div>
        </div>
    </div>

    @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
    {
        <!-- Bulk Release Modal -->
        <div class="modal fade" id="bulkReleaseModal" tabindex="-1" aria-labelledby="bulkReleaseModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form asp-controller="PickingLeitstand" asp-action="BulkRelease" method="post" id="bulkReleaseModalForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="release" value="true" />
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <div id="bulkReleaseModalIds"></div>
                        <div class="modal-header">
                            <h5 class="modal-title" id="bulkReleaseModalLabel">Sammel-Freigabe</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schliessen"></button>
                        </div>
                        <div class="modal-body">
                            <p><strong id="bulkReleaseModalCount">0</strong> Auftraege werden freigegeben.</p>
                            <div class="mb-3">
                                <label for="bulkAssignedPickerIdSelect" class="form-label">Kommissionierer zuweisen</label>
                                <select name="assignedPickerId" id="bulkAssignedPickerIdSelect" class="form-select" required>
                                    <option value="">— Bitte auswaehlen —</option>
                                    @foreach (var p in activePickers)
                                    {
                                        <option value="@p.Id">@p.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Abbrechen</button>
                            <button type="submit" id="bulkReleaseModalSubmit" class="btn btn-primary" disabled>Freigeben</button>
