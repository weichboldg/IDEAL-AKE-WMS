@model List<IdealAkeWms.Models.User>
@inject IdealAkeWms.Services.ICurrentUserService _user
@{
    ViewData["Title"] = "Benutzer";
    var canEdit = await _user.HasMasterDataAccessAsync();
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Benutzer</h2>
    <div class="d-flex gap-2">
        <a asp-action="RoleOverview" class="btn btn-outline-secondary btn-sm">Rollen-Uebersicht</a>
        @if (canEdit)
        {
            <a asp-action="Create" class="btn btn-primary">Neuen Benutzer anlegen</a>
        }
    </div>
</div>

@if (!canEdit)
{
    <div class="alert alert-info small">Sie haben Nur-Lesen-Zugriff. Aenderungen sind nicht moeglich.</div>
}

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table" data-server-column-filter="true" data-view-key="Users">
        <thead>
            <tr>
                <th data-filterable data-col-key="name">Name</th>
                <th data-filterable data-col-key="personal-number">Personalnummer</th>
                <th data-filterable data-col-key="roles">Rollen</th>
                <th data-filterable data-col-key="email">E-Mail</th>
                <th data-filterable data-col-key="status">Status</th>
                <th data-filterable data-col-key="created-at">Erstellt am</th>
                <th data-col-key="actions" style="width: 100px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.PersonalNumber</td>
                    <td>
                        @foreach (var ur in user.UserRoles.OrderBy(ur => ur.Role.SortOrder))
                        {
                            var badgeClass = ur.Role.Key == "admin" ? "bg-danger" : "bg-primary";
                            <span class="badge @badgeClass me-1">@ur.Role.Name</span>
                        }
                    </td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.IsActive)
                        {
                            <span class="badge badge-active">Aktiv</span>
                        }
                        else
                        {
                            <span class="badge badge-inactive">Inaktiv</span>
                        }
                    </td>
                    <td>@user.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (canEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-secondary">Bearbeiten</a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Keine Benutzer vorhanden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.Pagination is IdealAkeWms.Models.ViewModels.PaginationState paginationState)
{
    <partial name="_Pagination" model="paginationState" />
}

@section Scripts {
    <script src="~/js/column-preferences.js" asp-append-version="true"></script>
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
}
