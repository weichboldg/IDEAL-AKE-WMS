@model MovementHistoryViewModel
@{
    ViewData["Title"] = "Bewegungshistorie";
}

<h2 class="page-header">Bewegungshistorie</h2>

<div class="card filter-card mb-4">
    <div class="card-header">Filter</div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Von</label>
                    <input type="date" name="dateFrom" value="@Model.FilterDateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bis</label>
                    <input type="date" name="dateTo" value="@Model.FilterDateTo?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Artikel</label>
                    <input type="text" name="filterArticle" value="@Model.FilterArticle" class="form-control" placeholder="Artikelnr. oder Bezeichnung" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Lagerplatz</label>
                    <select name="filterStorageLocationId" class="form-select">
                        <option value="">-- Alle --</option>
                        @foreach (var sl in Model.StorageLocations)
                        {
                            <option value="@sl.Id" selected="@(Model.FilterStorageLocationId == sl.Id)">@sl.Code</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Bewegungsart</label>
                    <select name="filterMovementType" class="form-select">
                        <option value="">-- Alle --</option>
                        <option value="0" selected="@(Model.FilterMovementType == MovementType.Einbuchung)">Einbuchung</option>
                        <option value="1" selected="@(Model.FilterMovementType == MovementType.Ausbuchung)">Ausbuchung</option>
                        <option value="2" selected="@(Model.FilterMovementType == MovementType.Umbuchung)">Umbuchung</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Benutzer</label>
                    <select name="filterUserId" class="form-select">
                        <option value="">-- Alle --</option>
                        @foreach (var user in Model.Users)
                        {
                            <option value="@user.Id" selected="@(Model.FilterUserId == user.Id)">@user.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fertigungsauftrag</label>
                    <input type="text" name="filterProductionOrder" value="@Model.FilterProductionOrder" class="form-control" />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-secondary">Filtern</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Zurücksetzen</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table">
        <thead>
            <tr>
                <th data-filterable data-col-key="datetime">Datum/Zeit</th>
                <th data-filterable data-col-key="article">Artikel</th>
                <th data-filterable data-col-key="quantity">Menge</th>
                <th data-filterable data-col-key="storage-location">Lagerplatz</th>
                <th data-filterable data-col-key="movement-type">Bewegungsart</th>
                <th data-filterable data-col-key="user">Benutzer</th>
                <th data-filterable data-col-key="production-order">Fertigungsauftrag</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Timestamp.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <strong>@item.ArticleNumber</strong>
                        <a href="http://akevault24.ake.at/AutodeskTC/AKE-VAULT01/explore?search=@item.ArticleNumber&searchContext=0" target="_blank" title="Zeichnung in Vault öffnen" class="vault-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/>
                                <path d="M4.5 12.5A.5.5 0 0 1 5 12h3a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-2A.5.5 0 0 1 5 10h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m1.639-3.708 1.33.886 1.854-1.855a.25.25 0 0 1 .289-.047l1.888.974V7.5a.5.5 0 0 1-.5.5H5a.5.5 0 0 1-.5-.5V7s1.54-1.274 1.639-1.208M6.25 6a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5"/>
                            </svg>
                        </a>
                        @if (!string.IsNullOrEmpty(item.ArticleDescription))
                        {
                            <br /><small class="text-muted">@item.ArticleDescription</small>
                        }
                    </td>
                    <td>@item.Quantity.ToString("N3")</td>
                    <td>
                        @if (item.MovementType == MovementType.Umbuchung && !string.IsNullOrEmpty(item.SourceStorageLocationCode))
                        {
                            @item.SourceStorageLocationCode <span class="text-muted">&rarr;</span> @item.StorageLocationCode
                        }
                        else
                        {
                            @item.StorageLocationCode
                        }
                    </td>
                    <td>
                        @{
                            var badgeClass = item.MovementType == MovementType.Einbuchung ? "badge-einbuchung" :
                                             item.MovementType == MovementType.Umbuchung ? "badge-umbuchung" : "badge-ausbuchung";
                        }
                        <span class="@badgeClass">
                            @item.MovementTypeName
                        </span>
                    </td>
                    <td>@item.UserName</td>
                    <td>@item.ProductionOrder</td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Keine Bewegungen gefunden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
        <div class="text-muted">
            <small>Seite @Model.Page von @Model.TotalPages (@Model.TotalCount Einträge gesamt)</small>
        </div>
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new {
                    dateFrom = Model.FilterDateFrom?.ToString("yyyy-MM-dd"),
                    dateTo = Model.FilterDateTo?.ToString("yyyy-MM-dd"),
                    filterArticle = Model.FilterArticle,
                    filterStorageLocationId = Model.FilterStorageLocationId,
                    filterMovementType = Model.FilterMovementType.HasValue ? (int?)Model.FilterMovementType : null,
                    filterUserId = Model.FilterUserId,
                    filterProductionOrder = Model.FilterProductionOrder,
                    page = Model.Page - 1,
                    pageSize = Model.PageSize
                })">
                    &laquo; Zurück
                </a>
            </li>
            @{
                // Seitennummern: max 7 Seiten anzeigen
                int startPage = Math.Max(1, Model.Page - 3);
                int endPage = Math.Min(Model.TotalPages, startPage + 6);
                startPage = Math.Max(1, endPage - 6);
            }
            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new {
                        dateFrom = Model.FilterDateFrom?.ToString("yyyy-MM-dd"),
                        dateTo = Model.FilterDateTo?.ToString("yyyy-MM-dd"),
                        filterArticle = Model.FilterArticle,
                        filterStorageLocationId = Model.FilterStorageLocationId,
                        filterMovementType = Model.FilterMovementType.HasValue ? (int?)Model.FilterMovementType : null,
                        filterUserId = Model.FilterUserId,
                        filterProductionOrder = Model.FilterProductionOrder,
                        page = 1,
                        pageSize = Model.PageSize
                    })">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                }
            }
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new {
                        dateFrom = Model.FilterDateFrom?.ToString("yyyy-MM-dd"),
                        dateTo = Model.FilterDateTo?.ToString("yyyy-MM-dd"),
                        filterArticle = Model.FilterArticle,
                        filterStorageLocationId = Model.FilterStorageLocationId,
                        filterMovementType = Model.FilterMovementType.HasValue ? (int?)Model.FilterMovementType : null,
                        filterUserId = Model.FilterUserId,
                        filterProductionOrder = Model.FilterProductionOrder,
                        page = i,
                        pageSize = Model.PageSize
                    })">@i</a>
                </li>
            }
            @if (endPage < Model.TotalPages)
            {
                @if (endPage < Model.TotalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
                }
                <li class="page-item">
                    <a class="page-link" href="@Url.Action("Index", new {
                        dateFrom = Model.FilterDateFrom?.ToString("yyyy-MM-dd"),
                        dateTo = Model.FilterDateTo?.ToString("yyyy-MM-dd"),
                        filterArticle = Model.FilterArticle,
                        filterStorageLocationId = Model.FilterStorageLocationId,
                        filterMovementType = Model.FilterMovementType.HasValue ? (int?)Model.FilterMovementType : null,
                        filterUserId = Model.FilterUserId,
                        filterProductionOrder = Model.FilterProductionOrder,
                        page = Model.TotalPages,
                        pageSize = Model.PageSize
                    })">@Model.TotalPages</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new {
                    dateFrom = Model.FilterDateFrom?.ToString("yyyy-MM-dd"),
                    dateTo = Model.FilterDateTo?.ToString("yyyy-MM-dd"),
                    filterArticle = Model.FilterArticle,
                    filterStorageLocationId = Model.FilterStorageLocationId,
                    filterMovementType = Model.FilterMovementType.HasValue ? (int?)Model.FilterMovementType : null,
                    filterUserId = Model.FilterUserId,
                    filterProductionOrder = Model.FilterProductionOrder,
                    page = Model.Page + 1,
                    pageSize = Model.PageSize
                })">
                    Weiter &raquo;
                </a>
            </li>
        </ul>
    </nav>
}
else
{
    <div class="mt-3 text-muted">
        <small>@Model.TotalCount Einträge</small>
    </div>
}

@section Scripts {
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
}
