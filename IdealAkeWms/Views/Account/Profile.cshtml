@model IdealAkeWms.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Mein Profil";
}

<h2 class="page-header">Mein Profil</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="Profile" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" value="@Model.Name" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="PersonalNumber" class="form-label"></label>
                        <input type="text" class="form-control" value="@Model.PersonalNumber" disabled />
                    </div>

                    <hr />
                    <h6 class="text-muted">Stücklisten-Filter Standardwerte</h6>

                    <div class="mb-3">
                        <label asp-for="DefaultFilterBeschaffung" class="form-label"></label>
                        <input asp-for="DefaultFilterBeschaffung" class="form-control" placeholder="z.B. Ja oder Nein" />
                        <div class="form-text">Wird beim Öffnen einer Stückliste automatisch als Filter gesetzt.</div>
                        <span asp-validation-for="DefaultFilterBeschaffung" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultFilterArtikelgruppe" class="form-label"></label>
                        <input asp-for="DefaultFilterArtikelgruppe" class="form-control" placeholder="z.B. 886 - Isoliergläser" />
                        <div class="form-text">Wird beim Öffnen einer Stückliste automatisch als Filter gesetzt.</div>
                        <span asp-validation-for="DefaultFilterArtikelgruppe" class="text-danger"></span>
                    </div>

                    <div class="mt-2">
                        <div class="form-check">
                            <input asp-for="RecursiveFilterSearch" class="form-check-input" type="checkbox" />
                            <label asp-for="RecursiveFilterSearch" class="form-check-label"></label>
                            <div class="form-text">
                                Wenn aktiv, werden bei geöffneter Stückliste alle Positionen angezeigt,
                                die dem Filter entsprechen – unabhängig vom Baum-Status der Baugruppen.
                            </div>
                        </div>
                    </div>

                    <hr />
                    <h6 class="text-muted">Benachrichtigungen</h6>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="vorname.nachname@ake.at" />
                        <div class="form-text">Wird für automatische Benachrichtigungen (z.B. Meldebestand) verwendet.</div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input asp-for="NotifyOnReorderLevel" class="form-check-input" type="checkbox" />
                            <label asp-for="NotifyOnReorderLevel" class="form-check-label"></label>
                            <div class="form-text">
                                Wenn aktiv, werden automatisch Benachrichtigungen bei Meldebestand-Unterschreitung
                                an die oben eingetragene E-Mail-Adresse gesendet.
                            </div>
                        </div>
                    </div>

                    <hr />
                    <h6 class="text-muted">Listen-Ansicht</h6>

                    <div class="mb-3">
                        <label asp-for="DefaultPageSize" class="form-label"></label>
                        <select asp-for="DefaultPageSize" class="form-select">
                            <option value="">Standard (25)</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                            <option value="0">Alle</option>
                        </select>
                        <div class="form-text">
                            Gilt fuer alle paginierten Listen (FA, Leitstand, Bestand, Bewegungen, ...).
                            Die Auswahl am Seitenende ueberschreibt diesen Default fuer die aktuelle Seite.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultWorkStepId" class="form-label"></label>
                        <select asp-for="DefaultWorkStepId" class="form-select">
                            <option value="">(keiner)</option>
                            @foreach (var ws in Model.AvailableWorkSteps)
                            {
                                <option value="@ws.Id">@ws.Code — @ws.Name</option>
                            }
                        </select>
                        <div class="form-text">
                            Wird in der FA-Abarbeitungsliste automatisch vorausgewaehlt.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DefaultWorkplaceId" class="form-label"></label>
                        <select asp-for="DefaultWorkplaceId" class="form-select">
                            <option value="">(alle)</option>
                            @foreach (var wp in Model.AvailableWorkplaces)
                            {
                                <option value="@wp.Id">@wp.Name</option>
                            }
                        </select>
                        <div class="form-text">
                            Zusatzfilter in der FA-Abarbeitungsliste. (alle) = keine Vorauswahl.
                        </div>
                    </div>

                    <hr />

                    <div class="mb-3">
                        <label class="form-label">Passwort ändern</label>
                        <input type="password" name="newPassword" class="form-control" placeholder="Neues Passwort (leer = unverändert)" autocomplete="new-password" />
                        <div class="form-text">Nur ausfüllen wenn das Passwort geändert werden soll.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Speichern</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
