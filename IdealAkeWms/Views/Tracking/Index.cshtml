@model TrackingViewModel
@{
    ViewData["Title"] = "Teileverfolgung";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Teileverfolgung — Auftragsübersicht</h2>
</div>

<div class="card filter-card mb-4">
    <div class="card-header">Filter</div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">FA-Nummer</label>
                    <input type="text" name="filterOrderNumber" value="@Model.FilterOrderNumber" class="form-control" placeholder="z.B. FA-001" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Werkbank</label>
                    <select name="filterWorkplaceId" class="form-select">
                        <option value="">-- Alle Werkbänke --</option>
                        @foreach (var wp in Model.AvailableWorkplaces)
                        {
                            <option value="@wp.Id" selected="@(Model.FilterWorkplaceId == wp.Id)">@wp.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="form-check mt-4">
                        <input type="checkbox" name="showReported" value="true" class="form-check-input"
                               id="showReported" @(Model.ShowReported ? "checked" : "") />
                        <label class="form-check-label" for="showReported">Rückgemeldete anzeigen</label>
                    </div>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-secondary">Filtern</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Zurücksetzen</a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.OrderGroups.Any())
{
    <div class="alert alert-info">
        Keine Arbeitsgänge gefunden.
        @if (!Model.ShowReported)
        {
            <text> Möglicherweise sind alle bereits rückgemeldet — aktivieren Sie "Rückgemeldete anzeigen".</text>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>FA-Nr.</th>
                    <th>Artikelnr.</th>
                    <th>Bezeichnung</th>
                    <th>Kunde</th>
                    <th>Fertigungstermin</th>
                    <th>Werkbank</th>
                    <th>Fortschritt</th>
                    <th style="width: 50px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var group in Model.OrderGroups)
                {
                    var progress = group.TotalOperations > 0
                        ? (double)group.ReportedOperations / group.TotalOperations * 100
                        : 0;
                    var badgeClass = group.ReportedOperations == group.TotalOperations ? "bg-success"
                        : group.ReportedOperations > 0 ? "bg-warning text-dark"
                        : "bg-secondary";

                    <tr class="table-light" data-bs-toggle="collapse" data-bs-target="#ops-@group.ProductionOrderId"
                        style="cursor: pointer;">
                        <td><strong>@group.OrderNumber</strong></td>
                        <td>@group.ArticleNumber</td>
                        <td>@group.Description1</td>
                        <td>@group.Customer</td>
                        <td>
                            @if (group.ProductionDate.HasValue)
                            {
                                @group.ProductionDate.Value.ToString("dd.MM.yyyy")
                            }
                        </td>
                        <td>@group.WorkplaceName</td>
                        <td>
                            <span class="badge @badgeClass">@group.ReportedOperations / @group.TotalOperations</span>
                        </td>
                        <td>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-down" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"/>
                            </svg>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="8" class="p-0">
                            <div class="collapse" id="ops-@group.ProductionOrderId">
                              <div class="nested-table-responsive">
                                <table class="table table-sm mb-0 ms-4" style="width: calc(100% - 2rem);">
                                    <thead>
                                        <tr class="text-muted small">
                                            <th>#</th>
                                            <th>AG-Nr.</th>
                                            <th>Bezeichnung</th>
                                            <th>Werkbank</th>
                                            <th>Status</th>
                                            <th>Rückgemeldet</th>
                                            <th style="width: 160px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var op in group.Operations)
                                        {
                                            <tr class="@(op.IsReported ? "table-success" : "")">
                                                <td>@op.Sequence</td>
                                                <td>@op.OperationNumber</td>
                                                <td>@op.Name</td>
                                                <td>@(op.WorkplaceName ?? "—")</td>
                                                <td>
                                                    @await Html.PartialAsync("_OperationStatusBadge", op)
                                                </td>
                                                <td>
                                                    @if (op.IsReported && op.ReportedAt.HasValue)
                                                    {
                                                        <small>@op.ReportedAt.Value.ToString("dd.MM.yyyy HH:mm") — @op.ReportedBy</small>
                                                    }
                                                </td>
                                                <td>
                                                    @if (Model.CanReport && op.IsReportable)
                                                    {
                                                        if (!op.IsReported)
                                                        {
                                                            <form asp-action="Report" method="post" class="d-inline">
                                                                <input type="hidden" name="id" value="@op.Id" />
                                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                                <button type="submit" class="btn btn-sm btn-success">Rückmelden</button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <form asp-action="UndoReport" method="post" class="d-inline">
                                                                <input type="hidden" name="id" value="@op.Id" />
                                                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                                                <button type="submit" class="btn btn-sm btn-outline-secondary">Zurücknehmen</button>
                                                            </form>
                                                        }
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                              </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
