@model IdealAkeWms.Models.ViewModels.FaCompletionEditViewModel
@{
    ViewData["Title"] = $"FA {Model.OrderNumber} vervollständigen";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">FA @Model.OrderNumber</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Zur Übersicht</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning">@TempData["WarningMessage"]</div>
}

@* FA-Master-Info (read-only) *@
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2">
            <div class="col-md-4"><strong>Kunde:</strong> @Model.Customer</div>
            <div class="col-md-4"><strong>Artikel:</strong> @Model.ArticleNumber</div>
            <div class="col-md-4"><strong>Stk.:</strong> @Model.Quantity</div>
            <div class="col-md-4"><strong>Bezeichnung 1:</strong> @Model.Description1</div>
            <div class="col-md-4"><strong>Bezeichnung 2:</strong> @Model.Description2</div>
            <div class="col-md-4">
                <strong>Status:</strong>
                @if (Model.IsDone)
                {
                    <span class="badge bg-secondary">Erledigt</span>
                }
                else
                {
                    <span class="badge bg-success">Offen</span>
                }
            </div>
            <div class="col-md-4"><strong>Fert.-Termin:</strong> @(Model.ProductionDate?.ToString("dd.MM.yyyy"))</div>
            <div class="col-md-4"><strong>Liefertermin:</strong> @(Model.DeliveryDate?.ToString("dd.MM.yyyy"))</div>
        </div>
    </div>
</div>

@* Bootstrap-Nav-Tabs - URL-state via asp-route-tab *@
<ul class="nav nav-tabs mb-3">
    @foreach (var t in Model.Tabs)
    {
        var indicator = string.Empty;
        var badgeClass = string.Empty;
        if (t.IsApplicable && t.IsCompleted)
        {
            indicator = " ✓";
            badgeClass = "text-success";
        }
        else if (t.IsApplicable)
        {
            indicator = " ●";
            badgeClass = "text-warning";
        }
        <li class="nav-item">
            <a class="nav-link @(t.GroupKey == Model.ActiveTab ? "active" : "")"
               asp-action="Edit" asp-route-id="@Model.ProductionOrderId" asp-route-tab="@t.GroupKey">
                <strong>@t.GroupKey</strong> @t.GroupName<span class="@badgeClass small">@indicator</span>
            </a>
        </li>
    }
</ul>

@{
    var active = Model.Tabs.First(t => t.GroupKey == Model.ActiveTab);
}

<div class="tab-content">
    <div class="tab-pane fade show active">

        @* Flags-Bar mit zwei Switches *@
        <div class="d-flex flex-wrap gap-4 mb-3 align-items-center">

            @* IsApplicable - JSON-Dispatcher an /api/assembly-groups/toggle-applicable (Phase-1-API) *@
            <div class="form-check form-switch">
                <input class="form-check-input toggle-field" type="checkbox"
                       id="chkApplicable_@active.AssemblyGroupId"
                       data-id="@Model.ProductionOrderId"
                       data-endpoint="/api/assembly-groups/toggle-applicable"
                       data-group-key="@active.GroupKey"
                       @(active.IsApplicable ? "checked" : "") />
                <label class="form-check-label" for="chkApplicable_@active.AssemblyGroupId">
                    <strong>Anwendbar</strong> (<code>IsApplicable</code>)
                </label>
            </div>

            @* IsCompleted - Form-POST an /FaCompletion/ToggleIsCompleted (Server toggelt) *@
            <form method="post" asp-action="ToggleIsCompleted" class="form-check form-switch m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="assemblyGroupId" value="@active.AssemblyGroupId" />
                <input class="form-check-input" type="checkbox"
                       id="chkCompleted_@active.AssemblyGroupId"
                       onchange="this.form.submit()"
                       @(active.IsCompleted ? "checked" : "") />
                <label class="form-check-label" for="chkCompleted_@active.AssemblyGroupId">
                    <strong>Vervollständigt</strong> (<code>IsCompleted</code>)
                    @if (active.IsCompleted)
                    {
                        <span class="text-muted small">
                            — @active.CompletedBy am @active.CompletedAt?.ToString("dd.MM.yyyy HH:mm")
                        </span>
                    }
                </label>
            </form>
        </div>

        @* Spec-Tabelle: bestehende Specs als inline-editable Form-Rows *@
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th style="width: 22%;">Artikel</th>
                        <th>Beschreibung</th>
                        <th style="width: 10%;">Menge</th>
                        <th style="width: 18%;">Notizen</th>
                        <th style="width: 80px;">Sort.</th>
                        <th style="width: 170px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (active.Specs.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted small py-2">
                                Noch keine Ausprägungen für diese Baugruppe.
                            </td>
                        </tr>
                    }

                    @foreach (var spec in active.Specs)
                    {
                        var formId = $"frmEditSpec_{spec.Id}";
                        <tr>
                            @* EditSpec-Form liegt im 1. TD; weitere Inputs referenzieren sie via HTML5 form="..."-Attribut *@
                            <td>
                                <form method="post" asp-action="EditSpec" id="@formId" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Id" value="@spec.Id" />
                                    <input type="hidden" name="AssemblyGroupId" value="@spec.AssemblyGroupId" />
                                    <select name="ArticleId" class="form-select form-select-sm select2-article"
                                            data-pre-id="@(spec.ArticleId.HasValue ? spec.ArticleId.Value.ToString() : "")"
                                            data-pre-text="@(spec.ArticleText ?? "")">
                                        @if (spec.ArticleId.HasValue)
                                        {
                                            <option value="@spec.ArticleId" selected>@spec.ArticleText</option>
                                        }
                                    </select>
                                </form>
                            </td>
                            <td>
                                <input form="@formId" name="Description" class="form-control form-control-sm"
                                       value="@spec.Description" maxlength="500" required />
                            </td>
                            <td>
                                <input form="@formId" name="Quantity" type="number" step="0.001"
                                       class="form-control form-control-sm"
                                       value="@(spec.Quantity?.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                            </td>
                            <td>
                                <input form="@formId" name="Notes" class="form-control form-control-sm"
                                       value="@spec.Notes" />
                            </td>
                            <td>
                                <input form="@formId" name="SortOrder" type="number"
                                       class="form-control form-control-sm" value="@spec.SortOrder" />
                            </td>
                            <td class="text-nowrap">
                                <button type="submit" form="@formId" class="btn btn-sm btn-outline-primary">
                                    Speichern
                                </button>
                                <form method="post" asp-action="DeleteSpec" class="d-inline"
                                      onsubmit="return confirm('Ausprägung wirklich löschen?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@spec.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Löschen</button>
                                </form>
                            </td>
                        </tr>
                    }

                    @* Inline-Add-Row als letzte tbody-Zeile (eigene <form> ueber das colspan-TD) *@
                    <tr class="table-light">
                        <td colspan="6">
                            <form method="post" asp-action="AddSpec" class="row g-2 align-items-end">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="AssemblyGroupId" value="@active.AssemblyGroupId" />

                                <div class="col-md-3">
                                    <label class="form-label small mb-0">Artikel</label>
                                    <select name="ArticleId" class="form-select form-select-sm select2-article"
                                            data-pre-id="" data-pre-text=""></select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small mb-0">Beschreibung *</label>
                                    <input name="Description" class="form-control form-control-sm"
                                           required maxlength="500" placeholder="Ausprägung beschreiben" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small mb-0">Menge</label>
                                    <input name="Quantity" type="number" step="0.001" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label small mb-0">Notizen</label>
                                    <input name="Notes" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-1">
                                    <label class="form-label small mb-0">Sort.</label>
                                    <input name="SortOrder" type="number" class="form-control form-control-sm" value="0" />
                                </div>
                                <div class="col-md-1">
                                    <button type="submit" class="btn btn-primary btn-sm w-100" title="Hinzufügen">
                                        +
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

@section Scripts {
    @* Select2 fuer Article-Suche (verwendet bestehenden /api/articles/search Endpoint via _Select2ArticlePartial) *@
    <partial name="_Select2ArticlePartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // IsApplicable-Toggle - JSON-Dispatcher (Pattern analog PickingLeitstand/Index)
            document.querySelectorAll('.toggle-field').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var id = parseInt(this.getAttribute('data-id'));
                    var endpoint = this.getAttribute('data-endpoint');
                    var groupKey = this.getAttribute('data-group-key');
                    var value = this.checked;

                    if (endpoint !== '/api/assembly-groups/toggle-applicable') {
                        console.error('Unknown toggle-field endpoint:', endpoint);
                        cb.checked = !value;
                        return;
                    }

                    var body = { productionOrderId: id, groupKey: groupKey, value: value };

                    fetch(endpoint, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(body)
                    }).then(function (resp) {
                        if (!resp.ok) {
                            cb.checked = !value;
                            alert('Fehler beim Speichern.');
                        }
                    }).catch(function () {
                        cb.checked = !value;
                        alert('Fehler beim Speichern.');
                    });
                });
            });
        });
    </script>
}
