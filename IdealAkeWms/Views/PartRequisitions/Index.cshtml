@model IdealAkeWms.Models.ViewModels.PartRequisitionIndexViewModel
@using IdealAkeWms.Models
@{
    ViewData["Title"] = "Bestellungen";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Bestellungen</h2>
</div>

<div class="card filter-card mb-3">
    <div class="card-body py-2">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label mb-0 small">Suche</label>
                <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control form-control-sm"
                       placeholder="FA-Nr., Kunde, Artikelnr., Bezeichnung..." />
            </div>
            <div class="col-auto">
                <div class="form-check mt-1">
                    <input type="checkbox" class="form-check-input" id="showAll" name="showAll" value="true"
                           @(Model.ShowAll ? "checked" : "") />
                    <label class="form-check-label small" for="showAll">Alle anzeigen (inkl. Erfüllt/Storniert)</label>
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-secondary">Filtern</button>
            </div>
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.ShowAll)
            {
                <div class="col-auto">
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Zurücksetzen</a>
                </div>
            }
        </form>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        Keine Bestellungen gefunden.
        @if (!string.IsNullOrEmpty(Model.SearchTerm) || Model.ShowAll)
        {
            <text>Versuchen Sie andere Filterkriterien.</text>
        }
        else
        {
            <text>Aktuell liegen keine offenen Bedarfsmeldungen vor.</text>
        }
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
        <small class="text-muted">@Model.TotalCount Einträge gesamt — Seite @Model.CurrentPage von @Model.TotalPages</small>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-striped mb-0 filterable-table" style="width: max-content !important; white-space: nowrap;">
            <thead>
                <tr>
                    <th data-filterable data-col-key="status">Status</th>
                    <th data-filterable data-col-key="priority">Priorität</th>
                    <th data-filterable data-col-key="order-number">FA-Nr.</th>
                    <th data-filterable data-col-key="customer">Kunde</th>
                    <th data-filterable data-col-key="resource-number">Ressourcen-Nr.</th>
                    <th data-filterable data-col-key="description">Bezeichnung</th>
                    <th data-filterable data-col-key="quantity">Menge</th>
                    <th data-filterable data-col-key="unit">ME</th>
                    <th data-filterable data-col-key="ordered-by">Bestellt von</th>
                    <th data-filterable data-col-key="ordered-at">Bestellt am</th>
                    <th data-filterable data-col-key="email">E-Mail</th>
                    <th data-filterable data-col-key="remark">Bemerkung</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            @if (item.Status == PartRequisitionStatus.Offen)
                            {
                                <span class="badge bg-warning text-dark">Offen</span>
                            }
                            else if (item.Status == PartRequisitionStatus.Erfuellt)
                            {
                                <span class="badge bg-success">Erfüllt</span>
                            }
                            else if (item.Status == PartRequisitionStatus.Storniert)
                            {
                                <span class="badge bg-secondary">Storniert</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted">@item.Status</span>
                            }
                        </td>
                        <td>
                            @if (item.Priority == PartRequisitionPriority.Eilt)
                            {
                                <span class="badge bg-danger">Eilt</span>
                            }
                            else if (item.Priority == PartRequisitionPriority.Dringend)
                            {
                                <span class="badge bg-warning text-dark">Dringend</span>
                            }
                            else
                            {
                                <span class="text-muted small">Normal</span>
                            }
                        </td>
                        <td>
                            <a asp-controller="Picking" asp-action="Bom" asp-route-id="@item.ProductionOrderId"
                               title="Stückliste anzeigen">@item.OrderNumber</a>
                        </td>
                        <td>@item.Customer</td>
                        <td>
                            <code class="small">@item.ArticleNumber</code>
                        </td>
                        <td>
                            <span title="@item.ArticleDescription">
                                @(item.ArticleDescription?.Length > 40
                                    ? item.ArticleDescription[..40] + "…"
                                    : item.ArticleDescription)
                            </span>
                        </td>
                        <td class="text-end">@item.Quantity.ToString("N3")</td>
                        <td>@item.Unit</td>
                        <td>@item.CreatedBy</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="text-center">
                            @if (item.EmailSentAt.HasValue)
                            {
                                <span title="Gesendet: @item.EmailSentAt.Value.ToString("dd.MM.yyyy HH:mm")" data-bs-toggle="tooltip">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--ake-secondary)" viewBox="0 0 16 16">
                                        <path d="M2 2a2 2 0 0 0-2 2v8.01A2 2 0 0 0 2 14h5.5a.5.5 0 0 0 0-1H2a1 1 0 0 1-.966-.741l5.64-3.471L8 9.583l7-4.2V8.5a.5.5 0 0 0 1 0V4a2 2 0 0 0-2-2zm3.708 6.208L1 11.105V5.383zM1 4.217V4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v.217l-7 4.2z"/>
                                        <path d="M16 12.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0m-1.993-1.679a.5.5 0 0 0-.686.172l-1.17 1.95-.547-.547a.5.5 0 0 0-.708.708l.774.773a.75.75 0 0 0 1.174-.144l1.335-2.226a.5.5 0 0 0-.172-.686"/>
                                    </svg>
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.Notes))
                            {
                                <span title="@item.Notes" data-bs-toggle="tooltip">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" class="text-muted">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                                        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                                    </svg>
                                    <span class="visually-hidden">@item.Notes</span>
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (item.Status == PartRequisitionStatus.Offen)
                            {
                                <form asp-action="Cancel" method="post" class="d-inline" id="cancel-form-@item.Id">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="page" value="@Model.CurrentPage" />
                                    <input type="hidden" name="showAll" value="@Model.ShowAll.ToString().ToLower()" />
                                    @Html.AntiForgeryToken()
                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                            onclick="confirmCancel(@item.Id)"
                                            title="Bedarfsmeldung stornieren">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
                                        </svg>
                                        Stornieren
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Seitennavigation" class="mt-3">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-showAll="@(Model.ShowAll ? "true" : null)"
                       asp-route-page="@(Model.CurrentPage - 1)">‹</a>
                </li>
                @{
                    int startPage = Math.Max(1, Model.CurrentPage - 4);
                    int endPage = Math.Min(Model.TotalPages, startPage + 8);
                    if (endPage - startPage < 8)
                        startPage = Math.Max(1, endPage - 8);
                }
                @if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-showAll="@(Model.ShowAll ? "true" : null)"
                           asp-route-page="1">1</a>
                    </li>
                    @if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-showAll="@(Model.ShowAll ? "true" : null)"
                           asp-route-page="@i">@i</a>
                    </li>
                }
                @if (endPage < Model.TotalPages)
                {
                    @if (endPage < Model.TotalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" asp-action="Index"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-showAll="@(Model.ShowAll ? "true" : null)"
                           asp-route-page="@Model.TotalPages">@Model.TotalPages</a>
                    </li>
                }
                <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-showAll="@(Model.ShowAll ? "true" : null)"
                       asp-route-page="@(Model.CurrentPage + 1)">›</a>
                </li>
            </ul>
        </nav>
    }
    else
    {
        <div class="mt-2 text-muted"><small>@Model.TotalCount Einträge</small></div>
    }
}

@* Modal für Stornier-Bestätigung *@
<div class="modal fade" id="cancelConfirmModal" tabindex="-1" aria-labelledby="cancelConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cancelConfirmModalLabel">Bedarfsmeldung stornieren</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
            </div>
            <div class="modal-body">
                Soll diese Bedarfsmeldung wirklich storniert werden?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-danger btn-sm" id="btnConfirmCancel">Stornieren</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
    <script>
        var pendingCancelId = null;

        function confirmCancel(id) {
            pendingCancelId = id;
            var modal = new bootstrap.Modal(document.getElementById('cancelConfirmModal'));
            modal.show();
        }

        document.getElementById('btnConfirmCancel').addEventListener('click', function () {
            if (pendingCancelId !== null) {
                document.getElementById('cancel-form-' + pendingCancelId).submit();
            }
        });

        // Tooltips initialisieren
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
            tooltipEls.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });
        });
    </script>
}
