@model ProductionOrderViewModel
@using System.Globalization
@{
    var pageTitle = Model.LeitstandAktiv && Model.CanManagePickingRelease ? "Produktionsaufträge" : "Fertigungsaufträge";
    ViewData["Title"] = pageTitle;
    var today = DateTime.Today;
    // ISO 8601 Kalenderwoche berechnen
    string FormatDateWithKw(DateTime? date)
    {
        if (!date.HasValue) return "";
        var d = date.Value;
        var kw = ISOWeek.GetWeekOfYear(d);
        return $"{d:dd.MM.yyyy} KW{kw}";
    }
}

<h2 class="page-header">@pageTitle</h2>

<div class="card filter-card mb-4">
    <div class="card-header">Filter</div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">FA Nummer</label>
                    <input type="text" name="filterOrderNumber" value="@Model.FilterOrderNumber" class="form-control" placeholder="FA Nummer" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Artikelnummer</label>
                    <input type="text" name="filterArticleNumber" value="@Model.FilterArticleNumber" class="form-control" placeholder="Artikelnummer" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Kunde</label>
                    <input type="text" name="filterCustomer" value="@Model.FilterCustomer" class="form-control" placeholder="Kunde" />
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <div class="form-check mb-2">
                        <input type="checkbox" name="showDone" value="true" class="form-check-input" id="showDone"
                               @(Model.ShowDone ? "checked" : "") />
                        <label class="form-check-label" for="showDone">Erledigte anzeigen</label>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-secondary">Filtern</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Zurücksetzen</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table">
        <thead>
            <tr>
                @if (Model.CanPick)
                {
                    <th style="width: 40px;"></th>
                }
                <th style="width: 90px;" data-filterable data-col="1">FA Nr.</th>
                <th class="text-end" style="width: 55px;">Stk.</th>
                <th data-filterable data-col="3">Kunde</th>
                <th data-filterable data-col="4">Artikelnummer</th>
                <th data-filterable data-col="5">Bezeichnung 1</th>
                <th data-filterable data-col="6">Bezeichnung 2</th>
                <th data-filterable data-col="7">Werkbank</th>
                <th class="text-nowrap" data-filterable data-col="8" data-date-filter title="Kommissioniertermin - @Model.BeschichtungTage Arbeitstage">Beschicht.</th>
                <th class="text-nowrap" data-filterable data-col="9" data-date-filter title="Kommissioniertermin - @Model.VorkommissionierTage Arbeitstag(e)">BG-Termin</th>
                <th class="text-nowrap" data-filterable data-col="10" data-date-filter title="Fertigungstermin - @Model.KommissionierTage Arbeitstage">Komm.</th>
                <th class="text-nowrap" data-filterable data-col="11" data-date-filter>Fert.-Termin</th>
                <th class="text-nowrap" data-filterable data-col="12" data-date-filter>Liefertermin</th>
                <th style="width: 45px;" data-filterable data-col="13">Glas</th>
                <th style="width: 55px;" data-filterable data-col="14">Zukauf</th>
                <th data-filterable data-col="15">Status</th>
                <th style="width: 80px;"></th>
                @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
                {
                    <th style="width: 160px;">Freigabe</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr class="@(item.IsDone ? "table-secondary" : "")">
                    @if (Model.CanPick)
                    {
                        <td class="text-nowrap">
                            @if (!string.IsNullOrEmpty(item.ArticleNumber))
                            {
                                <a asp-action="Bom" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1" title="Stückliste">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6zm1.5.5A.5.5 0 0 1 1 13V6a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5z"/>
                                    </svg>
                                </a>
                            }
                        </td>
                    }
                    <td>
                        <strong>@item.OrderNumber</strong>
                        @if (Model.EnaioDmsLinks.TryGetValue(item.OrderNumber, out var dmsLinks))
                        {
                            foreach (var dms in dmsLinks)
                            {
                                var dmsUrl = $"http://akeosapp.ake.at/oscontentviewer/viewer/{dms.EnaioDmsObjectId}/?pagecount=1";
                                var dmsTitle = dms.DocumentType == "Zeichnung" ? "Zeichnung in enaio oeffnen" : "Dokument in enaio oeffnen";
                                if (dms.DocumentType == "Zeichnung")
                                {
                                    <a href="@dmsUrl" target="_blank" title="@dmsTitle" class="dms-link"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M4.502 9a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/><path d="M14.002 13a2 2 0 0 1-2 2h-10a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v10zM14 2H2a1 1 0 0 0-1 1v6.5l2.7-2.7a.5.5 0 0 1 .6-.1L9 10l2.6-2.6a.5.5 0 0 1 .7 0L15 10V3a1 1 0 0 0-1-1"/></svg></a>
                                }
                                else
                                {
                                    <a href="@dmsUrl" target="_blank" title="@dmsTitle" class="dms-link"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/></svg></a>
                                }
                            }
                        }
                    </td>
                    <td class="text-end">@item.Quantity.ToString("N3")</td>
                    <td>@item.Customer</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ArticleNumber))
                        {
                            <strong>@item.ArticleNumber</strong>
                            <a href="http://akevault24.ake.at/AutodeskTC/AKE-VAULT01/explore?search=@item.ArticleNumber&searchContext=0" target="_blank" title="Zeichnung in Vault öffnen" class="vault-link">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/>
                                    <path d="M4.5 12.5A.5.5 0 0 1 5 12h3a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-2A.5.5 0 0 1 5 10h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m1.639-3.708 1.33.886 1.854-1.855a.25.25 0 0 1 .289-.047l1.888.974V7.5a.5.5 0 0 1-.5.5H5a.5.5 0 0 1-.5-.5V7s1.54-1.274 1.639-1.208M6.25 6a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5"/>
                                </svg>
                            </a>
                        }
                    </td>
                    <td>@item.Description1</td>
                    <td>@item.Description2</td>
                    <td>@item.WorkplaceName</td>
                    <td class="@(!item.IsDone && item.BeschichtungTermin.HasValue && item.BeschichtungTermin.Value < today ? "text-danger fw-bold" : "")">
                        @FormatDateWithKw(item.BeschichtungTermin)
                    </td>
                    <td class="@(!item.IsDone && item.VorkommissionierTermin.HasValue && item.VorkommissionierTermin.Value < today ? "text-danger fw-bold" : "")">
                        @FormatDateWithKw(item.VorkommissionierTermin)
                    </td>
                    <td class="@(!item.IsDone && item.KommissionierTermin.HasValue && item.KommissionierTermin.Value < today ? "text-danger fw-bold" : "kommissionier-date")">
                        @FormatDateWithKw(item.KommissionierTermin)
                    </td>
                    <td>@FormatDateWithKw(item.ProductionDate)</td>
                    <td>@FormatDateWithKw(item.DeliveryDate)</td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field" data-id="@item.Id" data-field="HasGlass"
                               @(item.HasGlass ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td class="text-center">
                        <input type="checkbox" class="form-check-input toggle-field" data-id="@item.Id" data-field="HasExternalPurchase"
                               @(item.HasExternalPurchase ? "checked" : "") @(!Model.CanPick ? "disabled" : "") />
                    </td>
                    <td>
                        @if (item.IsDone)
                        {
                            <span class="badge bg-secondary">Erledigt</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Offen</span>
                        }
                        @if (!string.IsNullOrEmpty(item.PickingStatus))
                        {
                            if (item.PickingStatus == "abgeschlossen")
                            {
                                <span class="badge badge-picking-done ms-1">Komm.</span>
                            }
                            else if (item.PickingStatus == "teilkommissioniert")
                            {
                                <span class="badge badge-picking-partial ms-1">Teilkomm.</span>
                            }
                        }
                    </td>
                    <td class="text-nowrap">
                        <a asp-controller="Tracking" asp-action="OseonIndex" asp-route-filterCustomerOrder="@item.OrderNumber" asp-route-showFinished="true"
                           class="btn btn-sm btn-outline-info me-1" title="OSEON Teileverfolgung">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.399l-.451.004.09-.41h2.281z"/>
                                <path d="M8 5.5a1 1 0 1 0 0-2 1 1 0 0 0 0 2"/>
                            </svg>
                        </a>
                        @if (Model.CanPick)
                        {
                            <form asp-action="ToggleDone" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-sm @(item.IsDone ? "btn-outline-success" : "btn-outline-secondary")"
                                        title="@(item.IsDone ? "Als offen markieren" : "Als erledigt markieren")">
                                    @if (item.IsDone)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"/>
                                            <path d="M14 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1zM2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2z"/>
                                        </svg>
                                    }
                                </button>
                            </form>
                        }
                    </td>
                    @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
                    {
                        <td class="text-center text-nowrap">
                            @if (!item.IsDone)
                            {
                                <form asp-action="ToggleRelease" method="post" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                    @if (item.IsReleasedForPicking)
                                    {
                                        <button type="submit" class="btn btn-sm btn-success me-1" title="Freigabe zurücknehmen">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/>
                                            </svg>
                                        </button>
                                    }
                                    else if (!string.IsNullOrEmpty(item.ArticleNumber))
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="Zur Kommissionierung freigeben">
                                            Freigeben
                                        </button>
                                    }
                                </form>
                                @if (item.IsReleasedForPicking)
                                {
                                    <input type="number" class="form-control form-control-sm d-inline-block priority-input"
                                           value="@item.PickingPriority" min="1" style="width:55px"
                                           data-id="@item.Id" title="Priorität (1 = höchste)" />
                                }
                            }
                        </td>
                    }
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    @{
                        var colCount = 16;
                        if (Model.CanPick) colCount++;
                        if (Model.LeitstandAktiv && Model.CanManagePickingRelease) colCount++;
                    }
                    <td colspan="@colCount" class="text-center text-muted py-4">Keine @pageTitle gefunden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-3 text-muted">
    <small>@Model.Items.Count Einträge</small>
</div>

@section Scripts {
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Default-Sortierung: Kommissionierung (col 10) aufsteigend
            if (typeof triggerSort === 'function') triggerSort(10, 'asc');

            // Glas/Zukauf Checkbox-Toggle per AJAX
            document.querySelectorAll('.toggle-field').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    var id = parseInt(this.getAttribute('data-id'));
                    var field = this.getAttribute('data-field');
                    var value = this.checked;
                    fetch('/api/productionorders/toggle-field', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id: id, field: field, value: value })
                    }).then(function (resp) {
                        if (!resp.ok) {
                            cb.checked = !value;
                            alert('Fehler beim Speichern.');
                        }
                    }).catch(function () {
                        cb.checked = !value;
                        alert('Fehler beim Speichern.');
                    });
                });
            });
        });
    </script>
    @if (Model.LeitstandAktiv && Model.CanManagePickingRelease)
    {
        <script>
            document.querySelectorAll('.priority-input').forEach(function (input) {
                input.addEventListener('click', function (e) { e.stopPropagation(); e.preventDefault(); });
                input.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); this.blur(); } });
                input.addEventListener('change', function () {
                    var id = this.getAttribute('data-id');
                    var priority = this.value ? parseInt(this.value) : null;
                    var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    $.ajax({
                        url: '@Url.Action("SetPriority")',
                        type: 'POST',
                        data: { id: id, priority: priority },
                        headers: { 'RequestVerificationToken': token },
                        error: function () { alert('Fehler beim Speichern der Priorität.'); }
                    });
                });
            });
        </script>
    }
}
