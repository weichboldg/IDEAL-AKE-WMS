@model List<Workstation>
@inject IdealAkeWms.Services.ICurrentUserService _user
@{
    ViewData["Title"] = "Arbeitsplätze";
    var canEdit = await _user.HasMasterDataAccessAsync();
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Arbeitsplätze</h2>
    @if (canEdit)
    {
        <a asp-action="Create" class="btn btn-primary">Neuen Arbeitsplatz anlegen</a>
    }
</div>

@if (!canEdit)
{
    <div class="alert alert-info small">Sie haben Nur-Lesen-Zugriff. Aenderungen sind nicht moeglich.</div>
}

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table" data-server-column-filter="true" data-view-key="Workstations">
        <thead>
            <tr>
                <th data-filterable data-col-key="name">Bezeichnung</th>
                <th data-filterable data-col-key="location">Standort</th>
                <th data-filterable data-col-key="default-printer">Standard-Drucker</th>
                <th data-filterable data-col-key="default-user">Standard-Benutzer</th>
                <th data-filterable data-col-key="users">Zugeordnete Benutzer</th>
                <th data-col-key="actions" style="width: 100px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ws in Model)
            {
                <tr>
                    <td><strong>@ws.Name</strong></td>
                    <td>@ws.Location</td>
                    <td><code>@ws.DefaultPrinter</code></td>
                    <td>@ws.DefaultUser?.Name</td>
                    <td>
                        @foreach (var wu in ws.WorkstationUsers)
                        {
                            <span class="badge bg-secondary me-1">@wu.User.Name</span>
                        }
                    </td>
                    <td>
                        @if (canEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@ws.Id" class="btn btn-sm btn-secondary">Bearbeiten</a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">Keine Arbeitsplätze vorhanden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.Pagination is IdealAkeWms.Models.ViewModels.PaginationState paginationState)
{
    <partial name="_Pagination" model="paginationState" />
}

@section Scripts {
    <script src="~/js/column-preferences.js" asp-append-version="true"></script>
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
}
