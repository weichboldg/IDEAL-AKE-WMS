@model OrderRecipientGroupViewModel
@{
    ViewData["Title"] = "Empfängergruppe bearbeiten";
}

<h2 class="page-header">Empfängergruppe bearbeiten</h2>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="card-title mb-0">Gruppendetails</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" autofocus />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Gruppe speichern</button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Empfänger</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>E-Mail</th>
                                <th style="width: 80px;">Aktiv</th>
                                <th style="width: 180px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var recipient in Model.Recipients)
                            {
                                var recipientId = $"recipient-{recipient.Id}";
                                <tr>
                                    <td>
                                        <input type="text" id="@(recipientId)-name" value="@recipient.Name" class="form-control form-control-sm" required />
                                    </td>
                                    <td>
                                        <input type="email" id="@(recipientId)-email" value="@recipient.Email" class="form-control form-control-sm" required />
                                    </td>
                                    <td class="text-center">
                                        <input type="checkbox" id="@(recipientId)-active" class="form-check-input" @(recipient.IsActive ? "checked" : "") />
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <form asp-action="UpdateRecipient" asp-route-groupId="@Model.Id" method="post"
                                                  onsubmit="var p='@recipientId'; this.querySelector('[name=Name]').value=document.getElementById(p+'-name').value; this.querySelector('[name=Email]').value=document.getElementById(p+'-email').value; this.querySelector('[name=IsActive]').value=document.getElementById(p+'-active').checked;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="Id" value="@recipient.Id" />
                                                <input type="hidden" name="Name" value="" />
                                                <input type="hidden" name="Email" value="" />
                                                <input type="hidden" name="IsActive" value="false" />
                                                <button type="submit" class="btn btn-sm btn-secondary">Speichern</button>
                                            </form>
                                            <form asp-action="DeleteRecipient" asp-route-groupId="@Model.Id" asp-route-recipientId="@recipient.Id" method="post"
                                                  onsubmit="return confirm('Empfänger wirklich entfernen?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Löschen</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Recipients.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">Keine Empfänger in dieser Gruppe.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer">
                <h6 class="mb-3">Neuer Empfänger</h6>
                <form asp-action="AddRecipient" asp-route-groupId="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Name</label>
                            <input type="text" name="Name" class="form-control" required placeholder="Max Mustermann" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">E-Mail</label>
                            <input type="email" name="Email" class="form-control" required placeholder="max@example.com" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Aktiv</label>
                            <div>
                                <input type="hidden" name="IsActive" value="true" />
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" checked />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Hinzufügen</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="btn btn-outline-secondary">Zurück zur Übersicht</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
