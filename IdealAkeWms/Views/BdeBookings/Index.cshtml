@model IdealAkeWms.Models.ViewModels.BdeBookingsIndexViewModel
@inject IdealAkeWms.Services.ICurrentUserService CurrentUserService
@using System.Globalization
@{
    ViewData["Title"] = "BDE-Buchungen";
    var operators = ViewBag.Operators as List<IdealAkeWms.Models.BdeOperator> ?? new List<IdealAkeWms.Models.BdeOperator>();
    var workplaces = ViewBag.Workplaces as List<IdealAkeWms.Models.ProductionWorkplace> ?? new List<IdealAkeWms.Models.ProductionWorkplace>();
    var filter = ViewBag.Filter;
    int skip = (int)(filter?.skip ?? 0);
    int take = (int)(filter?.take ?? 50);
    int? operatorId = (int?)filter?.operatorId;
    int? workplaceId = (int?)filter?.workplaceId;
    DateTime? from = (DateTime?)filter?.from;
    DateTime? to = (DateTime?)filter?.to;
    var canAdminBde = await CurrentUserService.CanManageBdeAdminAsync();

    string FormatDateWithKw(DateTime? date)
    {
        if (!date.HasValue) return "";
        var d = date.Value;
        var kw = ISOWeek.GetWeekOfYear(d);
        return $"{d:dd.MM.yyyy HH:mm} KW{kw}";
    }
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="mb-0">BDE-Buchungen</h2>
</div>

<form method="get" class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label" for="from">Von</label>
                <input type="date" id="from" name="from" class="form-control" value="@(from?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="to">Bis</label>
                <input type="date" id="to" name="to" class="form-control" value="@(to?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="operatorId">Operator</label>
                <select id="operatorId" name="operatorId" class="form-select">
                    <option value="">— alle —</option>
                    @foreach (var op in operators)
                    {
                        @if (operatorId == op.Id)
                        {
                            <option value="@op.Id" selected>@op.DisplayName</option>
                        }
                        else
                        {
                            <option value="@op.Id">@op.DisplayName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="workplaceId">Werkbank</label>
                <select id="workplaceId" name="workplaceId" class="form-select">
                    <option value="">— alle —</option>
                    @foreach (var wp in workplaces)
                    {
                        @if (workplaceId == wp.Id)
                        {
                            <option value="@wp.Id" selected>@wp.Name</option>
                        }
                        else
                        {
                            <option value="@wp.Id">@wp.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-12">
                <input type="hidden" name="take" value="@take" />
                <button type="submit" class="btn btn-primary">Filtern</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Zurücksetzen</a>
            </div>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle filterable-table" data-view-key="BdeBookings" data-fallback-sort-column="started-at" data-fallback-sort-direction="desc">
        <thead>
            <tr>
                <th data-filterable data-col-key="started-at" data-date-filter>Start</th>
                <th data-filterable data-col-key="ended-at" data-date-filter>Ende</th>
                <th data-col-key="effective-duration">Effektive Zeit</th>
                <th data-filterable data-col-key="operator">Operator</th>
                <th data-filterable data-col-key="workplace">Werkbank</th>
                <th data-filterable data-col-key="booking-type">Typ</th>
                <th data-filterable data-col-key="target">Ziel</th>
                <th class="text-end" data-filterable data-col-key="good-qty">Gut</th>
                <th class="text-end" data-filterable data-col-key="scrap-qty">Ausschuss</th>
                <th data-filterable data-col-key="status">Status</th>
                @if (canAdminBde)
                {
                    <th data-col-key="actions">Aktionen</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Bookings.Any())
            {
                <tr><td colspan="10" class="text-center text-muted">Keine Buchungen gefunden.</td></tr>
            }
            else
            {
                foreach (var row in Model.Bookings)
                {
                    <tr>
                        <td data-col-key="started-at">@FormatDateWithKw(row.StartedAt)</td>
                        <td data-col-key="ended-at">@(row.EndedAt.HasValue ? FormatDateWithKw(row.EndedAt) : "—")</td>
                        <td data-col-key="effective-duration">
                            @{
                                var eff = Model.EffectiveDurations.GetValueOrDefault(row.Id, TimeSpan.Zero);
                                var runningSuffix = row.EndedAt == null ? "*" : "";
                            }
                            <span title="@(row.EndedAt == null ? "Wird nach Beenden angepasst" : "")">
                                @eff.ToString(@"hh\:mm")@runningSuffix
                            </span>
                        </td>
                        <td data-col-key="operator">@row.OperatorName</td>
                        <td data-col-key="workplace">@row.WorkplaceName</td>
                        <td data-col-key="booking-type">@row.BookingType</td>
                        <td data-col-key="target">@(row.Target ?? "—")</td>
                        <td class="text-end" data-col-key="good-qty">@row.TotalGood.ToString("0.##")</td>
                        <td class="text-end" data-col-key="scrap-qty">@row.TotalScrap.ToString("0.##")</td>
                        <td data-col-key="status">@row.Status</td>
                        <td data-col-key="actions">
                            @if (canAdminBde)
                            {
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@row.Id" class="btn btn-outline-primary">Bearbeiten</a>
                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#cancelModal-@row.Id">Stornieren</button>
                                    @if (row.EndedAt == null)
                                    {
                                        <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#closeModal-@row.Id">Manuell schließen</button>
                                    }
                                </div>

                                <div class="modal fade" id="cancelModal-@row.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <form method="post" asp-action="Cancel" asp-route-id="@row.Id" class="modal-content">
                                            @Html.AntiForgeryToken()
                                            <div class="modal-header">
                                                <h5 class="modal-title">Buchung #@row.Id stornieren</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                                            </div>
                                            <div class="modal-body">
                                                <label for="reason-@row.Id" class="form-label">Stornogrund</label>
                                                <textarea id="reason-@row.Id" name="reason" class="form-control" rows="3" maxlength="500" required></textarea>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                                                <button type="submit" class="btn btn-danger">Stornieren</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>

                                @if (row.EndedAt == null)
                                {
                                    <div class="modal fade" id="closeModal-@row.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <form method="post" asp-action="ManualClose" asp-route-id="@row.Id" class="modal-content">
                                                @Html.AntiForgeryToken()
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Buchung #@row.Id manuell schließen</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schließen"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <label for="endedAt-@row.Id" class="form-label">Endezeitpunkt</label>
                                                    <input type="datetime-local" id="endedAt-@row.Id" name="endedAt" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                                                    <button type="submit" class="btn btn-warning">Schließen</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<nav aria-label="Paginierung">
    <ul class="pagination">
        @if (skip > 0)
        {
            var prevSkip = Math.Max(0, skip - take);
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-skip="@prevSkip" asp-route-take="@take"
                   asp-route-operatorId="@operatorId" asp-route-workplaceId="@workplaceId"
                   asp-route-from="@(from?.ToString("yyyy-MM-dd"))" asp-route-to="@(to?.ToString("yyyy-MM-dd"))">« Zurück</a>
            </li>
        }
        @if (Model.Bookings.Count >= take)
        {
            var nextSkip = skip + take;
            <li class="page-item">
                <a class="page-link" asp-action="Index"
                   asp-route-skip="@nextSkip" asp-route-take="@take"
                   asp-route-operatorId="@operatorId" asp-route-workplaceId="@workplaceId"
                   asp-route-from="@(from?.ToString("yyyy-MM-dd"))" asp-route-to="@(to?.ToString("yyyy-MM-dd"))">Weiter »</a>
            </li>
        }
    </ul>
</nav>

@section Scripts {
    <script src="~/js/column-preferences.js" asp-append-version="true"></script>
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
}
