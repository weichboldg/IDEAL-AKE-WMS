@model IdealAkeWms.Models.ViewModels.BdeBookingEditViewModel
@using IdealAkeWms.Models
@{
    ViewData["Title"] = "BDE-Buchung bearbeiten";
    var operators = ViewBag.Operators as List<IdealAkeWms.Models.BdeOperator> ?? new List<IdealAkeWms.Models.BdeOperator>();
    var workplaces = ViewBag.Workplaces as List<IdealAkeWms.Models.ProductionWorkplace> ?? new List<IdealAkeWms.Models.ProductionWorkplace>();
}

<h2>Buchung bearbeiten <small class="text-muted">#@Model.Id</small></h2>

<form method="post" asp-action="Edit" asp-route-id="@Model.Id">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="card mb-3">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="BdeOperatorId" class="form-label"></label>
                    <select asp-for="BdeOperatorId" class="form-select">
                        @foreach (var op in operators)
                        {
                            @if (op.Id == Model.BdeOperatorId)
                            {
                                <option value="@op.Id" selected>@op.DisplayName</option>
                            }
                            else
                            {
                                <option value="@op.Id">@op.DisplayName</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ProductionWorkplaceId" class="form-label"></label>
                    <select asp-for="ProductionWorkplaceId" class="form-select">
                        @foreach (var wp in workplaces)
                        {
                            @if (wp.Id == Model.ProductionWorkplaceId)
                            {
                                <option value="@wp.Id" selected>@wp.Name</option>
                            }
                            else
                            {
                                <option value="@wp.Id">@wp.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label asp-for="StartedAt" class="form-label"></label>
                    <input asp-for="StartedAt" type="datetime-local" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="EndedAt" class="form-label"></label>
                    <input asp-for="EndedAt" type="datetime-local" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<BdeBookingStatus>()"></select>
                </div>
            </div>
        </div>
    </div>

    <h4>Mengen</h4>
    <div class="table-responsive mb-3">
        <table class="table table-sm table-bordered align-middle">
            <thead>
                <tr>
                    <th>Gutmenge</th>
                    <th>Ausschuss</th>
                    <th>Abschluss</th>
                    <th>Gemeldet</th>
                    <th>Löschen</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Quantities.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted">Keine Mengen erfasst.</td></tr>
                }
                else
                {
                    for (int i = 0; i < Model.Quantities.Count; i++)
                    {
                        <tr>
                            <td>
                                <input type="hidden" asp-for="Quantities[i].Id" />
                                <input type="number" step="0.01" asp-for="Quantities[i].GoodQuantity" class="form-control form-control-sm" />
                            </td>
                            <td><input type="number" step="0.01" asp-for="Quantities[i].ScrapQuantity" class="form-control form-control-sm" /></td>
                            <td class="text-center">
                                <input type="hidden" name="Quantities[@i].IsFinal" value="false" />
                                <input type="checkbox" name="Quantities[@i].IsFinal" value="true" @(Model.Quantities[i].IsFinal ? "checked" : "") />
                            </td>
                            <td><input type="datetime-local" asp-for="Quantities[i].ReportedAt" class="form-control form-control-sm" /></td>
                            <td class="text-center">
                                <input type="hidden" name="Quantities[@i].Delete" value="false" />
                                <input type="checkbox" name="Quantities[@i].Delete" value="true" />
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Speichern</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
    </div>
</form>
