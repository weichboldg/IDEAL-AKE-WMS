@model SettingsViewModel
@{
    ViewData["Title"] = "Einstellungen";
}

<h2 class="page-header">Einstellungen</h2>

<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header">Konfiguration</div>
            <div class="card-body">
                <form asp-action="SaveSettings" method="post">
                    @Html.AntiForgeryToken()
                    @foreach (var setting in Model.Settings)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">@setting.Key</label>
                            @if (!string.IsNullOrEmpty(setting.Description))
                            {
                                <br /><small class="text-muted">@setting.Description</small>
                            }
                            <input type="text" name="settings[@setting.Key]" value="@setting.Value" class="form-control" />
                        </div>
                    }
                    <button type="submit" class="btn btn-primary">Einstellungen speichern</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                Feiertage
                <form asp-action="SyncHolidays" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-light" title="Österreichische Feiertage automatisch importieren">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41m-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9"/>
                            <path fill-rule="evenodd" d="M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5 5 0 0 0 8 3M3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9z"/>
                        </svg>
                        Synchronisieren
                    </button>
                </form>
            </div>
            <div class="card-body">
                <form asp-action="AddHoliday" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Datum</label>
                            <input type="date" name="date" class="form-control" required />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Bezeichnung</label>
                            <input type="text" name="description" class="form-control" placeholder="z.B. Nationalfeiertag" />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100">Hinzufügen</button>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Datum</th>
                                <th>Bezeichnung</th>
                                <th style="width: 60px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var holiday in Model.Holidays)
                            {
                                <tr>
                                    <td>@holiday.Date.ToString("dd.MM.yyyy")</td>
                                    <td>@holiday.Description</td>
                                    <td>
                                        <form asp-action="DeleteHoliday" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@holiday.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Löschen"
                                                    onclick="return confirm('Feiertag wirklich löschen?');">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Holidays.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-3">Keine Feiertage hinterlegt.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
