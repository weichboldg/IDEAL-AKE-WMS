@model SettingsViewModel
@{
    ViewData["Title"] = "Einstellungen";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Einstellungen</h2>
    <a asp-action="OperationConfig" class="btn btn-outline-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1">
            <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0"/>
            <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52z"/>
        </svg>
        Arbeitsgang-Konfiguration
    </a>
</div>

<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header">Konfiguration</div>
            <div class="card-body">
                <form asp-action="SaveSettings" method="post">
                    @Html.AntiForgeryToken()
                    @foreach (var setting in Model.Settings)
                    {
                        var isBool = string.Equals(setting.Value, "true", StringComparison.OrdinalIgnoreCase)
                                  || string.Equals(setting.Value, "false", StringComparison.OrdinalIgnoreCase);
                        var isChecked = string.Equals(setting.Value, "true", StringComparison.OrdinalIgnoreCase);
                        <div class="mb-3">
                            <label class="form-label fw-bold">@setting.Key</label>
                            @if (!string.IsNullOrEmpty(setting.Description))
                            {
                                <br /><small class="text-muted">@setting.Description</small>
                            }
                            @if (isBool)
                            {
                                <input type="hidden" name="settings[@setting.Key]" value="@(isChecked ? "true" : "false")" class="bool-hidden" />
                                <div class="form-check form-switch mt-1">
                                    <input type="checkbox" class="form-check-input bool-toggle" id="setting_@setting.Key"
                                           @(isChecked ? "checked" : "") />
                                    <label class="form-check-label" for="setting_@setting.Key">
                                        @(isChecked ? "Aktiviert" : "Deaktiviert")
                                    </label>
                                </div>
                            }
                            else
                            {
                                <input type="text" name="settings[@setting.Key]" value="@setting.Value" class="form-control" />
                            }
                        </div>
                    }
                    <button type="submit" class="btn btn-primary">Einstellungen speichern</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                Feiertage
                <form asp-action="SyncHolidays" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-light" title="Österreichische Feiertage automatisch importieren">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M11.534 7h3.932a.25.25 0 0 1 .192.41l-1.966 2.36a.25.25 0 0 1-.384 0l-1.966-2.36a.25.25 0 0 1 .192-.41m-11 2h3.932a.25.25 0 0 0 .192-.41L2.692 6.23a.25.25 0 0 0-.384 0L.342 8.59A.25.25 0 0 0 .534 9"/>
                            <path fill-rule="evenodd" d="M8 3c-1.552 0-2.94.707-3.857 1.818a.5.5 0 1 1-.771-.636A6.002 6.002 0 0 1 13.917 7H12.9A5 5 0 0 0 8 3M3.1 9a5.002 5.002 0 0 0 8.757 2.182.5.5 0 1 1 .771.636A6.002 6.002 0 0 1 2.083 9z"/>
                        </svg>
                        Synchronisieren
                    </button>
                </form>
            </div>
            <div class="card-body">
                <form asp-action="AddHoliday" method="post" class="mb-3">
                    @Html.AntiForgeryToken()
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">Datum</label>
                            <input type="date" name="date" class="form-control" required />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Bezeichnung</label>
                            <input type="text" name="description" class="form-control" placeholder="z.B. Nationalfeiertag" />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100">Hinzufügen</button>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Datum</th>
                                <th>Bezeichnung</th>
                                <th style="width: 60px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var holiday in Model.Holidays)
                            {
                                <tr>
                                    <td>@holiday.Date.ToString("dd.MM.yyyy")</td>
                                    <td>@holiday.Description</td>
                                    <td>
                                        <form asp-action="DeleteHoliday" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@holiday.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Löschen"
                                                    onclick="return confirm('Feiertag wirklich löschen?');">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                                                </svg>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Holidays.Any())
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-3">Keine Feiertage hinterlegt.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.bool-toggle').forEach(function (cb) {
            cb.addEventListener('change', function () {
                var hidden = this.closest('.mb-3').querySelector('.bool-hidden');
                if (hidden) hidden.value = this.checked ? 'true' : 'false';
                var label = this.parentElement.querySelector('.form-check-label');
                if (label) label.textContent = this.checked ? 'Aktiviert' : 'Deaktiviert';
            });
        });
    </script>
}
