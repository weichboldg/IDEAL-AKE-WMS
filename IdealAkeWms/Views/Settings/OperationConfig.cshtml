@model IdealAkeWms.Models.ViewModels.OseonOperationConfigViewModel
@{
    ViewData["Title"] = "Arbeitsgang-Konfiguration";
}

<h2 class="page-header">Arbeitsgang-Konfiguration (OSEON)</h2>
<p class="text-muted mb-3">
    Konfigurieren Sie pro Arbeitsgang den Soll-Termin (Offset in Arbeitstagen relativ zum Stanztermin)
    und ob der AG fuer die OSEON-Statusberechnung relevant ist.
</p>

<div class="row">
    <div class="col-lg-8 mb-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                Konfigurierte Arbeitsgaenge
                <a asp-action="Index" class="btn btn-sm btn-light">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                    </svg>
                    Zurueck zu Einstellungen
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>AG-Name</th>
                                <th>Anzeigename</th>
                                <th style="width: 130px;">Offset (AT)</th>
                                <th style="width: 130px;">OSEON-relevant</th>
                                <th style="width: 140px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var config in Model.Configs)
                            {
                                <tr>
                                    <td>
                                        <strong>@config.OperationName</strong>
                                    </td>
                                    <td>
                                        <form asp-action="UpdateOperationConfig" method="post" class="d-flex align-items-center gap-1" id="form-update-@config.Id">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@config.Id" />
                                            <input type="text" name="displayName" value="@config.DisplayName" class="form-control form-control-sm" placeholder="z.B. Stanzen" />
                                        </form>
                                    </td>
                                    <td>
                                        <input type="number" name="dueDateOffsetDays" value="@config.DueDateOffsetDays" form="form-update-@config.Id" class="form-control form-control-sm text-center" />
                                    </td>
                                    <td class="text-center">
                                        <input type="hidden" name="isOseonRelevant" value="@(config.IsOseonRelevant ? "true" : "false")" form="form-update-@config.Id" id="hidden-oseon-@config.Id" />
                                        <input type="checkbox" class="form-check-input" form="form-update-@config.Id"
                                               @(config.IsOseonRelevant ? "checked" : "")
                                               onchange="document.getElementById('hidden-oseon-@config.Id').value = this.checked ? 'true' : 'false'" />
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button type="submit" form="form-update-@config.Id" class="btn btn-sm btn-outline-primary" title="Speichern">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/>
                                                </svg>
                                            </button>
                                            <form asp-action="DeleteOperationConfig" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@config.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Loeschen"
                                                        onclick="return confirm('Arbeitsgang \'@config.OperationName\' wirklich loeschen?');">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                                                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                                                    </svg>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Configs.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-3">Keine Arbeitsgaenge konfiguriert.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header">Neuen Arbeitsgang hinzufuegen</div>
            <div class="card-body">
                <form asp-action="AddOperationConfig" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-bold">AG-Name</label>
                        @if (Model.UnconfiguredNames.Any())
                        {
                            <select name="operationName" class="form-select" id="operationNameSelect">
                                <option value="">-- Waehlen oder eingeben --</option>
                                @foreach (var name in Model.UnconfiguredNames)
                                {
                                    <option value="@name">@name (aus OSEON)</option>
                                }
                            </select>
                            <input type="text" id="operationNameInput" class="form-control mt-2" placeholder="Oder manuell eingeben..." />
                            <small class="text-muted">Waehlen Sie einen nicht konfigurierten AG aus OSEON oder geben Sie einen neuen Namen ein.</small>
                        }
                        else
                        {
                            <input type="text" name="operationName" class="form-control" placeholder="z.B. BG" required />
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Anzeigename</label>
                        <input type="text" name="displayName" class="form-control" placeholder="z.B. Biegen" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Offset (Arbeitstage)</label>
                        <input type="number" name="dueDateOffsetDays" value="0" class="form-control" />
                        <small class="text-muted">Negativ = vor Stanztermin, Positiv = nach Stanztermin</small>
                    </div>
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input type="hidden" name="isOseonRelevant" value="true" id="hidden-add-oseon" />
                            <input type="checkbox" class="form-check-input" id="addIsOseonRelevant" checked
                                   onchange="document.getElementById('hidden-add-oseon').value = this.checked ? 'true' : 'false'" />
                            <label class="form-check-label" for="addIsOseonRelevant">OSEON-relevant</label>
                        </div>
                        <small class="text-muted">Nicht-relevante AGs werden bei der Statusberechnung ignoriert.</small>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Hinzufuegen</button>
                </form>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">Legende</div>
            <div class="card-body">
                <p class="mb-2"><strong>Offset (AT)</strong> = Arbeitstage relativ zum Stanztermin (OSEON Endtermin)</p>
                <ul class="mb-2 small">
                    <li><code>-1</code> = 1 Arbeitstag <em>vor</em> dem Stanztermin</li>
                    <li><code>0</code> = Am Stanztermin selbst</li>
                    <li><code>+2</code> = 2 Arbeitstage <em>nach</em> dem Stanztermin</li>
                </ul>
                <p class="mb-0"><strong>OSEON-relevant</strong> = Wird fuer die Fertig-Berechnung herangezogen. Wenn alle relevanten AGs fertig sind, gilt der Auftrag als erledigt.</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Wenn sowohl Select als auch manuelles Input vorhanden sind,
        // synchronisiere die Werte
        (function () {
            var select = document.getElementById('operationNameSelect');
            var input = document.getElementById('operationNameInput');
            if (!select || !input) return;

            select.addEventListener('change', function () {
                if (this.value) {
                    input.value = '';
                }
            });

            input.addEventListener('input', function () {
                if (this.value) {
                    select.value = '';
                    select.name = '';
                    input.name = 'operationName';
                } else {
                    select.name = 'operationName';
                    input.name = '';
                }
            });
        })();
    </script>
}
