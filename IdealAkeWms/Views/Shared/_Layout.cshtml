@inject IdealAkeWms.Services.ICurrentUserService CurrentUserService
@inject IdealAkeWms.Data.Repositories.IAppSettingRepository AppSettings
@inject IdealAkeWms.Data.Repositories.IProductionOrderRepository ProductionOrderRepository
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IDEAL-AKE WMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="~/images/ideal-ake-logo.svg" />
    <link rel="icon" href="~/favicon.ico" sizes="any" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="navbar-logo-wrapper">
                        <img src="~/images/ideal-ake-logo.svg" alt="IDEAL-AKE WMS" height="28" />
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Navigation umschalten">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @{
                            var canAccessStock = await CurrentUserService.CanAccessStockAsync();
                            var canPick = await CurrentUserService.CanPickAsync();
                            var canViewTracking = await CurrentUserService.CanViewTrackingAsync();
                            var teileverfolgungAktiv = (await AppSettings.GetValueAsync("TeileverfolgungAktiv"))?.Equals("true", StringComparison.OrdinalIgnoreCase) == true;
                            var bestellungenAktiv = (await AppSettings.GetValueAsync("BestellungenAktiv"))?.Equals("true", StringComparison.OrdinalIgnoreCase) == true;
                            var canManagePickingRelease = await CurrentUserService.CanManagePickingReleaseAsync();
                            var leitstandAktiv = (await AppSettings.GetValueAsync("LeitstandAktiv"))?.Equals("true", StringComparison.OrdinalIgnoreCase) == true;
                            var releasedPickingCount = leitstandAktiv && canPick ? await ProductionOrderRepository.GetReleasedForPickingCountAsync() : 0;
                            var canUseBde = await CurrentUserService.CanUseBdeAsync();
                            var canManageBdeShiftlead = await CurrentUserService.CanManageBdeShiftleadAsync();
                        }
                        @if (canAccessStock || canPick)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Lager
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="StockMovements" asp-action="Inbound">Einbuchung</a></li>
                                    <li><a class="dropdown-item" asp-controller="StockMovements" asp-action="Outbound">Ausbuchung</a></li>
                                    <li><a class="dropdown-item" asp-controller="StockMovements" asp-action="Transfer">Umbuchung</a></li>
                                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.2);" /></li>
                                    <li><a class="dropdown-item" asp-controller="StockOverview" asp-action="Index">Bestände</a></li>
                                    <li><a class="dropdown-item" asp-controller="StockMovements" asp-action="Index">Bewegungshistorie</a></li>
                                    @if (await CurrentUserService.CanTransferStockAsync())
                                    {
                                        <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.2);" /></li>
                                        <li><a class="dropdown-item" asp-controller="StockMovements" asp-action="OutboundAll">Lagerplatz ausbuchen</a></li>
                                        <li><a class="dropdown-item" asp-controller="StockMovements" asp-action="LocationTransfer">Lagerplatz umbuchen</a></li>
                                    }
                                </ul>
                            </li>
                        }
                        @if (leitstandAktiv)
                        {
                            @if (canManagePickingRelease || canViewTracking)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ProductionOrders" asp-action="Index">Fertigungsaufträge</a>
                                </li>
                            }
                        }
                        else
                        {
                            @if (canPick || canViewTracking)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="ProductionOrders" asp-action="Index">Fertigungsaufträge</a>
                                </li>
                            }
                        }
                        @if (canPick)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Picking" asp-action="Index">
                                    Kommissionierung
                                    @if (leitstandAktiv && releasedPickingCount > 0)
                                    {
                                        <span class="badge rounded-pill" style="background-color: var(--ake-orange); font-size: 0.7em;">@releasedPickingCount</span>
                                    }
                                </a>
                            </li>
                        }
                        @if (bestellungenAktiv && (canPick || canAccessStock))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PartRequisitions" ? "active" : "")" asp-controller="PartRequisitions" asp-action="Index">Bestellungen</a>
                            </li>
                        }
                        @if (teileverfolgungAktiv && canViewTracking)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Teileverfolgung
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Tracking" asp-action="Index">Rückmeldungen</a></li>
                                    <li><a class="dropdown-item" asp-controller="Tracking" asp-action="OseonIndex">OSEON Aufträge</a></li>
                                </ul>
                            </li>
                        }
                        @if (canUseBde)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    BDE
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="BdeTerminal" asp-action="Index">Terminal</a></li>
                                    @if (canManageBdeShiftlead)
                                    {
                                        <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.2);" /></li>
                                        <li><a class="dropdown-item" asp-controller="BdeCockpit" asp-action="Index">Cockpit</a></li>
                                        <li><a class="dropdown-item" asp-controller="BdeBookings" asp-action="Index">Buchungen</a></li>
                                        <li><a class="dropdown-item" asp-controller="BdeMasterData" asp-action="Index">Stammdaten</a></li>
                                    }
                                </ul>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Stammdaten
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Articles" asp-action="Index">Artikel</a></li>
                                <li><a class="dropdown-item" asp-controller="StorageLocations" asp-action="Index">Lagerplätze</a></li>
                                @if (await CurrentUserService.HasMasterDataAccessAsync())
                                {
                                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.2);" /></li>
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">Benutzer</a></li>
                                    <li><a class="dropdown-item" asp-controller="Workstations" asp-action="Index">Arbeitsplätze</a></li>
                                    <li><a class="dropdown-item" asp-controller="ProductionWorkplaces" asp-action="Index">Werkbänke</a></li>
                                    <li><a class="dropdown-item" asp-controller="Roles" asp-action="Index">Rollen</a></li>
                                    <li><a class="dropdown-item" asp-controller="ArticleCategories" asp-action="Index">Artikelkategorien</a></li>
                                    <li><a class="dropdown-item" asp-controller="ArticleAttributes" asp-action="Index">Artikelmerkmale</a></li>
                                    <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.2);" /></li>
                                    <li><a class="dropdown-item" asp-controller="Settings" asp-action="Index">Einstellungen</a></li>
                                    @if (await CurrentUserService.IsAdminAsync())
                                    {
                                        <li><a class="dropdown-item" asp-controller="ServiceSettings" asp-action="Index">Service-Einstellungen</a></li>
                                    }
                                    @if (bestellungenAktiv)
                                    {
                                        <li><hr class="dropdown-divider" style="border-color: rgba(255,255,255,0.2);" /></li>
                                        <li><a class="dropdown-item" asp-controller="OrderRecipients" asp-action="Index">Empfänger</a></li>
                                        <li><a class="dropdown-item" asp-controller="OrderRecipients" asp-action="ArticleGroupMappings">Artikelgruppen-Zuordnung</a></li>
                                    }
                                }
                            </ul>
                        </li>
                    </ul>
                    @* Desktop: user dropdown in navbar *@
                    <span class="user-info d-none d-lg-inline">
                        @if (Context.Session.GetInt32("AppUserId").HasValue)
                        {
                            <div class="dropdown d-inline">
                                <button class="btn btn-sm btn-outline-light dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    @Context.Session.GetString("AppUserName")
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            Mein Profil
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">Abmelden</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else if (User.Identity?.IsAuthenticated == true)
                        {
                            <span>@User.Identity.Name</span>
                        }
                    </span>
                    @* Mobile: user info inside collapsed menu *@
                    <div class="navbar-user-mobile d-lg-none">
                        @if (Context.Session.GetInt32("AppUserId").HasValue)
                        {
                            <span class="text-white-50 small d-block mb-2">
                                Angemeldet als <strong class="text-white">@Context.Session.GetString("AppUserName")</strong>
                            </span>
                            <div class="d-flex gap-2">
                                <a asp-controller="Account" asp-action="Profile" class="btn btn-sm btn-outline-light flex-fill">Mein Profil</a>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="flex-fill">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger w-100">Abmelden</button>
                                </form>
                            </div>
                        }
                        else if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-white-50 small">@User.Identity.Name</span>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-3 px-md-4 mt-3">
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
            </div>
        }
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Schließen"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container-fluid px-3 px-md-4 d-flex justify-content-between flex-wrap gap-2">
            <span>&copy; @DateTime.Now.Year IDEAL-AKE WMS v@(IdealAkeWms.AppVersion.Version)</span>
            <div class="d-flex gap-3">
                <a asp-controller="Help" asp-action="Changelog" class="text-white-50">Aenderungen</a>
                <a asp-controller="Help" asp-action="Index" class="text-white-50">Hilfe</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
