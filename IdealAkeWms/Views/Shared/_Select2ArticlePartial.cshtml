@* Select2 AJAX Article Search - CSS + JS *@

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/i18n/de.js"></script>

<script>
    $(function () {
        $('.select2-article').each(function () {
            var $el = $(this);
            var preId = $el.data('pre-id');
            var preText = $el.data('pre-text');

            $el.select2({
                theme: 'bootstrap-5',
                ajax: {
                    url: '/api/articles/search',
                    dataType: 'json',
                    delay: 300,
                    data: function (params) {
                        return { q: params.term, limit: 50 };
                    },
                    processResults: function (data) {
                        return { results: data };
                    },
                    cache: true
                },
                placeholder: '-- Artikel suchen --',
                minimumInputLength: 0,
                allowClear: true,
                language: 'de',
                width: '100%',
                dropdownParent: $el.closest('.input-group').length ? $el.closest('.mb-3') : undefined
            });

            // Pre-populate bei POST-Failure
            if (preId && preText) {
                var option = new Option(preText, preId, true, true);
                $el.append(option).trigger('change');
            }
        });
    });
</script>
