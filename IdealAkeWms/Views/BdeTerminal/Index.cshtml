@{
    ViewData["Title"] = "BDE-Terminal";
}

<link rel="stylesheet" href="~/css/bde.css" asp-append-version="true" />

<div class="container-fluid bde-terminal">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h2>
            BDE-Terminal
            <small class="text-muted">Werkbank:
                <select id="workplaceSwitch" class="form-select form-select-sm d-inline-block w-auto">
                    @foreach (var wp in (IEnumerable<dynamic>)ViewBag.AllWorkplaces)
                    {
                        <option value="@wp.Id" selected="@(wp.Id == ViewBag.WorkplaceId)">@wp.Name</option>
                    }
                </select>
            </small>
        </h2>
        <div class="text-muted small">
            Angemeldet: @(User.Identity?.Name) | Session läuft bis: <span id="sessionExpiry">—</span>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Scannen</div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Personalnummer oder FA-AG scannen</label>
                        <input type="text" id="scanInput" class="form-control form-control-lg" autofocus placeholder="Scannen…" />
                    </div>
                    <div id="scanFeedback" class="small text-muted"></div>
                    <button id="btnActivity" class="btn btn-outline-secondary mt-2">Ungeplante Tätigkeit</button>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Aktuelle Buchung</div>
                <div class="card-body" id="currentBooking">
                    <em class="text-muted">Keine aktive Buchung</em>
                </div>
            </div>
        </div>
    </div>

    <!-- Aktions-Buttons erscheinen dynamisch via JS -->
    <div id="actionPanel" class="mt-3"></div>

    <!-- Mengen-Modal -->
    <div class="modal fade" id="quantityModal" tabindex="-1">
      <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Mengen melden</h5></div>
        <div class="modal-body">
          <div class="mb-3"><label>Gutmenge</label><input type="number" id="inputGood" class="form-control form-control-lg" step="1" min="0" /></div>
          <div class="mb-3"><label>Ausschuss</label><input type="number" id="inputScrap" class="form-control form-control-lg" step="1" min="0" value="0" /></div>
        </div>
        <div class="modal-footer"><button id="btnQtyCancel" class="btn btn-secondary">Abbrechen</button><button id="btnQtyOk" class="btn btn-primary">Bestätigen</button></div>
      </div></div>
    </div>

    <!-- Kollisions-Modal -->
    <div class="modal fade" id="collisionModal" tabindex="-1">
      <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header bg-warning"><h5 class="modal-title">Arbeitsgang bereits in Arbeit</h5></div>
        <div class="modal-body"><p id="collisionText"></p></div>
        <div class="modal-footer"><button class="btn btn-primary" data-bs-dismiss="modal">OK</button></div>
      </div></div>
    </div>

    <!-- Aktivitäts-Modal -->
    <div class="modal fade" id="activityModal" tabindex="-1">
      <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Ungeplante Tätigkeit</h5></div>
        <div class="modal-body">
            <label>Kategorie</label>
            <select id="activitySelect" class="form-select form-select-lg"></select>
        </div>
        <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button><button id="btnActivityOk" class="btn btn-primary">Starten</button></div>
      </div></div>
    </div>
</div>

@section Scripts {
    <input type="hidden" id="terminalId" value="@ViewBag.TerminalId" />
    <input type="hidden" id="workplaceId" value="@ViewBag.WorkplaceId" />
    @Html.AntiForgeryToken()
    <script src="~/js/bde-terminal.js" asp-append-version="true"></script>
}
