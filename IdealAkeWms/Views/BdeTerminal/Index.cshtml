@{
    ViewData["Title"] = "BDE-Terminal";
}

<link rel="stylesheet" href="~/css/bde.css" asp-append-version="true" />

<div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080;"></div>

<div class="container-fluid bde-terminal">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h2>
            BDE-Terminal
            <small class="text-muted">Werkbank:
                <select id="workplaceSwitch" class="form-select form-select-sm d-inline-block w-auto">
                    @foreach (var wp in (IEnumerable<dynamic>)ViewBag.AllWorkplaces)
                    {
                        @if (wp.Id == (int)ViewBag.WorkplaceId)
                        {
                            <option value="@wp.Id" selected>@wp.Name</option>
                        }
                        else
                        {
                            <option value="@wp.Id">@wp.Name</option>
                        }
                    }
                </select>
            </small>
        </h2>
        <div class="text-muted small">
            Angemeldet: @(User.Identity?.Name) | Session läuft bis: <span id="sessionExpiry">—</span>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">1. Operator</div>
                <div class="card-body">
                    <div id="operatorInfo" class="d-none mb-3">
                        <div class="bde-operator-badge">
                            <span id="operatorName" class="fw-bold fs-4"></span>
                            <button id="btnChangeOperator" class="btn btn-sm btn-outline-secondary ms-2">Wechseln</button>
                        </div>
                    </div>
                    <div id="operatorScan">
                        <div class="input-group">
                            <input type="text" id="scanOperator" class="form-control form-control-lg" placeholder="Personalnummer scannen…" autofocus />
                            <button id="btnScanOperator" class="btn btn-primary btn-lg">Scannen</button>
                        </div>
                        <div id="operatorFeedback" class="small text-danger mt-1"></div>
                    </div>
                </div>
            </div>

            <div id="paused-bookings-hint" class="alert alert-warning mb-3 d-none" role="alert">
                <strong>Hinweis: Sie haben pausierte Auftraege</strong>
                <ul id="paused-bookings-list" class="list-unstyled mt-2 mb-0"></ul>
            </div>

            <div class="card mt-3" id="operationsCard" style="display:none">
                <div class="card-header">2. Arbeitsgang wählen</div>
                <div class="card-body">
                    <div id="operationButtons"></div>
                    <hr />
                    <div class="input-group mt-2">
                        <input type="text" id="scanFaAg" class="form-control" placeholder="Oder FA-Nr,AG-Nr scannen…" />
                        <button id="btnScanFaAg" class="btn btn-outline-primary">Scannen</button>
                    </div>
                    <div id="faAgFeedback" class="small text-danger mt-1"></div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Aktuelle Buchungen</div>
                <div id="active-bookings-container" class="card-body p-0">
                    <div id="active-bookings-empty" class="p-3 text-muted">
                        <em>Keine aktive Buchung</em>
                    </div>
                    <div id="active-bookings-list"></div>
                </div>
            </div>

            <div class="card mt-3" id="historyCard" style="display:none">
                <div class="card-header">Tageshistorie</div>
                <div class="card-body p-2" id="todayHistory">
                    <em class="text-muted">Noch keine Buchungen heute.</em>
                </div>
            </div>
        </div>
    </div>

    <!-- Aktions-Buttons erscheinen dynamisch via JS -->
    <div id="actionPanel" class="mt-3"></div>

    <!-- Mengen-Modal -->
    <div class="modal fade" id="quantityModal" tabindex="-1">
      <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Mengen melden</h5></div>
        <div class="modal-body">
          <div id="qty-sollmenge-hint" class="alert alert-info py-2 mb-3 d-none"></div>
          <div class="mb-3"><label>Gutmenge</label><input type="number" id="inputGood" class="form-control form-control-lg" step="1" min="0" /></div>
          <div class="mb-3"><label>Ausschuss</label><input type="number" id="inputScrap" class="form-control form-control-lg" step="1" min="0" value="0" /></div>
        </div>
        <div class="modal-footer"><button id="btnQtyCancel" class="btn btn-secondary">Abbrechen</button><button id="btnQtyOk" class="btn btn-primary">Bestätigen</button></div>
      </div></div>
    </div>

    <!-- Kollisions-Modal -->
    <div class="modal fade" id="collisionModal" tabindex="-1">
      <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header bg-warning"><h5 class="modal-title">Arbeitsgang bereits in Arbeit</h5></div>
        <div class="modal-body"><p id="collisionText"></p></div>
        <div class="modal-footer"><button class="btn btn-primary" data-bs-dismiss="modal">OK</button></div>
      </div></div>
    </div>

    <!-- Aktivitäts-Modal -->
    <div class="modal fade" id="activityModal" tabindex="-1">
      <div class="modal-dialog"><div class="modal-content">
        <div class="modal-header"><h5 class="modal-title">Ungeplante Tätigkeit</h5></div>
        <div class="modal-body">
            <label>Kategorie</label>
            <select id="activitySelect" class="form-select form-select-lg"></select>
        </div>
        <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button><button id="btnActivityOk" class="btn btn-primary">Starten</button></div>
      </div></div>
    </div>
</div>

<!-- Group-Finish-Modal -->
<div class="modal fade" id="group-finish-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Alle Produktionsauftr&auml;ge abschliessen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schliessen"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>FA / AG</th>
                                <th>Sollmenge</th>
                                <th>Gut</th>
                                <th>Ausschuss</th>
                                <th>Abschl.</th>
                            </tr>
                        </thead>
                        <tbody id="group-finish-rows"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-primary" id="group-finish-confirm">Alle fertig melden</button>
            </div>
        </div>
    </div>
</div>

<!-- Close-Others-Modal -->
<div class="modal fade" id="close-others-modal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Weitere aktive Buchungen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Schliessen"></button>
            </div>
            <div class="modal-body">
                <p>Auf diesem Arbeitsgang arbeiten noch:</p>
                <ul id="close-others-list"></ul>
                <p>Sollen diese Buchungen auch beendet werden?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Nein, nur meine</button>
                <button type="button" class="btn btn-primary" id="close-others-confirm">Ja, alle beenden</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <input type="hidden" id="terminalId" value="@ViewBag.TerminalId" />
    <input type="hidden" id="workplaceId" value="@ViewBag.WorkplaceId" />
    <input type="hidden" id="nurFaMode" value="@(ViewBag.NurFaMode != null && (bool)ViewBag.NurFaMode ? "true" : "false")" />
    @Html.AntiForgeryToken()
    <script src="~/js/bde-terminal.js" asp-append-version="true"></script>
}
