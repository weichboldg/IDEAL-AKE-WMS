@model List<ProductionWorkplace>
@inject IdealAkeWms.Services.ICurrentUserService _user
@{
    ViewData["Title"] = "Werkbänke";
    var canEdit = await _user.HasMasterDataAccessAsync();
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Werkbänke / Produktionsarbeitsplätze</h2>
    @if (canEdit)
    {
        <a asp-action="Create" class="btn btn-primary">Neue Werkbank anlegen</a>
    }
</div>

@if (!canEdit)
{
    <div class="alert alert-info small">Sie haben Nur-Lesen-Zugriff. Aenderungen sind nicht moeglich.</div>
}

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table" data-server-column-filter="true" data-view-key="ProductionWorkplaces">
        <thead>
            <tr>
                <th data-filterable data-col-key="name">Bezeichnung</th>
                <th data-filterable data-col-key="hall">Halle</th>
                <th data-filterable data-col-key="bde">BDE</th>
                <th data-filterable data-col-key="users">Benutzer</th>
                <th data-filterable data-col-key="pre-picking-days">Abw. Vorkommissioniertage</th>
                <th data-col-key="actions" style="width: 100px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var wp in Model)
            {
                <tr>
                    <td><strong>@wp.Name</strong></td>
                    <td>@wp.Hall</td>
                    <td>
                        @if (wp.BdeAktiv)
                        {
                            <span class="badge bg-success">Aktiv</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inaktiv</span>
                        }
                    </td>
                    <td>
                        @if (wp.ProductionWorkplaceUsers.Any())
                        {
                            <span class="badge bg-primary">@wp.ProductionWorkplaceUsers.Count</span>
                            <small class="text-muted ms-1">@string.Join(", ", wp.ProductionWorkplaceUsers.Select(wu => wu.User.Name))</small>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @if (wp.OverridePrePickingDays.HasValue)
                        {
                            <span class="badge bg-secondary">@wp.OverridePrePickingDays Tage</span>
                        }
                        else
                        {
                            <span class="text-muted">Standard</span>
                        }
                    </td>
                    <td>
                        @if (canEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@wp.Id" class="btn btn-sm btn-secondary">Bearbeiten</a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">Keine Werkbänke vorhanden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ViewBag.Pagination is IdealAkeWms.Models.ViewModels.PaginationState paginationState)
{
    <partial name="_Pagination" model="paginationState" />
}

@section Scripts {
    <script src="~/js/column-preferences.js" asp-append-version="true"></script>
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
}
