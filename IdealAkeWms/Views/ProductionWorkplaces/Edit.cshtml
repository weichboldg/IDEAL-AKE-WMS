@model ProductionWorkplaceEditViewModel
@{
    ViewData["Title"] = "Werkbank bearbeiten";
    var days = new[] {
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday,
        DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    };
    var dayLabels = new Dictionary<DayOfWeek, string> {
        { DayOfWeek.Monday, "Montag" }, { DayOfWeek.Tuesday, "Dienstag" },
        { DayOfWeek.Wednesday, "Mittwoch" }, { DayOfWeek.Thursday, "Donnerstag" },
        { DayOfWeek.Friday, "Freitag" }, { DayOfWeek.Saturday, "Samstag" }, { DayOfWeek.Sunday, "Sonntag" }
    };
}

<h2 class="page-header">Werkbank bearbeiten</h2>

<div class="row">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Hall" class="form-label"></label>
                        <input asp-for="Hall" class="form-control" />
                        <span asp-validation-for="Hall" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="OverridePrePickingDays" class="form-label"></label>
                        <input asp-for="OverridePrePickingDays" class="form-control" type="number" min="0" max="365" />
                        <div class="form-text">Leer lassen um den globalen Standard zu verwenden.</div>
                        <span asp-validation-for="OverridePrePickingDays" class="text-danger"></span>
                    </div>

                    <hr />
                    <h6 class="text-muted">Benutzer-Zuordnung</h6>

                    <div class="mb-3">
                        <label asp-for="SelectedUserIds" class="form-label"></label>
                        <select asp-for="SelectedUserIds" class="form-select" multiple size="6"
                                asp-items="@(new SelectList(Model.AvailableUsers ?? new List<User>(), "Id", "Name"))">
                        </select>
                        <small class="form-text text-muted">Halten Sie Strg gedrückt, um mehrere Benutzer auszuwählen.</small>
                    </div>

                    <hr />
                    <h6 class="text-muted">Arbeitsgang-Zuordnung</h6>

                    <div class="mb-3">
                        <label class="form-label">Vorbaugruppen / Arbeitsgaenge dieser Werkbank</label>
                        @if (!Model.AllWorkSteps.Any())
                        {
                            <div class="form-text">Keine aktiven Arbeitsgaenge vorhanden.</div>
                        }
                        @foreach (var ws in Model.AllWorkSteps)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="workStepIds" value="@ws.Id"
                                       id="ws_@ws.Id" @(Model.SelectedWorkStepIds.Contains(ws.Id) ? "checked" : "") />
                                <label class="form-check-label" for="ws_@ws.Id">@ws.Code — @ws.Name</label>
                            </div>
                        }
                    </div>

                    <div class="card mt-3">
                        <div class="card-header">BDE-Einstellungen</div>
                        <div class="card-body">
                            <div class="form-check form-switch mb-3">
                                <input asp-for="BdeAktiv" class="form-check-input" role="switch" />
                                <label asp-for="BdeAktiv" class="form-check-label"></label>
                                <div class="form-text">Werkbank erscheint in BDE-Cockpit, Terminal und Buchungsübersicht.</div>
                            </div>
                            <div class="mb-3">
                                <label asp-for="BdeDefaultArbeitsgang" class="form-label"></label>
                                <input asp-for="BdeDefaultArbeitsgang" class="form-control" placeholder="z.B. PRODUKTION (leer = globales Setting verwenden)" />
                                <div class="form-text">
                                    Überschreibt das globale Setting. Aktuell global: <strong>@ViewBag.GlobalDefaultArbeitsgang</strong>
                                </div>
                                <span asp-validation-for="BdeDefaultArbeitsgang" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="card mt-3">
                        <div class="card-header">Schichtplan (BDE)</div>
                        <div class="card-body">
                            <div class="form-check form-switch mb-2">
                                <input asp-for="BdeUseCustomShiftPlan" class="form-check-input" role="switch" id="bdeUseCustomShiftPlanSwitch" />
                                <label asp-for="BdeUseCustomShiftPlan" class="form-check-label"></label>
                            </div>
                            <div class="form-text mb-2">
                                Wenn aktiv, gelten die rechts gepflegten Schichten fuer diese Werkbank statt des Default-Plans.
                                Aenderungen am Toggle werden mit "Speichern" uebernommen.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Speichern</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Abbrechen</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (Model.Id > 0)
    {
        <div class="col-md-6 col-lg-7">
            <div id="custom-shifts-editor" class="card" style="@(Model.BdeUseCustomShiftPlan ? "" : "display:none;")">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span>Werkbank-Schichten</span>
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#add-custom-shift">+ Schicht hinzufuegen</button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Wochentag</th>
                                    <th>Beginn</th>
                                    <th>Ende</th>
                                    <th>Bezeichnung</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.CustomShifts.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-muted">Keine Schichten gepflegt.</td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var s in Model.CustomShifts)
                                    {
                                        <tr>
                                            <td>@dayLabels[s.DayOfWeek]</td>
                                            <td>@s.StartTime.ToString(@"hh\:mm")</td>
                                            <td>@s.EndTime.ToString(@"hh\:mm")</td>
                                            <td>@(string.IsNullOrWhiteSpace(s.Name) ? "—" : s.Name)</td>
                                            <td class="text-end">
                                                <form asp-controller="BdeShiftCalendar" asp-action="Delete" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@s.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Entfernen">&times;</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="add-custom-shift" tabindex="-1">
            <div class="modal-dialog">
                <form asp-controller="BdeShiftCalendar" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProductionWorkplaceId" value="@Model.Id" />
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Schicht hinzufuegen</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Wochentag</label>
                                <select name="DayOfWeek" class="form-select" required>
                                    @foreach (var d in days)
                                    {
                                        <option value="@((int)d)">@dayLabels[d]</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bezeichnung (optional)</label>
                                <input name="Name" class="form-control" placeholder="z.B. Frühschicht" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Beginn</label>
                                <input name="StartTime" type="time" class="form-control" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Ende</label>
                                <input name="EndTime" type="time" class="form-control" required />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                            <button type="submit" class="btn btn-primary">Speichern</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var sw = document.getElementById('bdeUseCustomShiftPlanSwitch');
            var editor = document.getElementById('custom-shifts-editor');
            if (sw && editor) {
                sw.addEventListener('change', function () {
                    editor.style.display = sw.checked ? '' : 'none';
                });
            }
        })();
    </script>
}
