@model ArticleIndexViewModel
@inject IdealAkeWms.Services.ICurrentUserService _user
@{
    ViewData["Title"] = "Artikel";
    var canEdit = await _user.HasMasterDataAccessAsync();
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <h2 class="page-header mb-0">Artikel</h2>
    @if (canEdit)
    {
        <a asp-action="Create" class="btn btn-primary">Neuen Artikel anlegen</a>
    }
</div>

@if (!canEdit)
{
    <div class="alert alert-info small">Sie haben Nur-Lesen-Zugriff. Aenderungen sind nicht moeglich.</div>
}

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label mb-0 small">Suche</label>
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="Artikelnummer oder Bezeichnung..." />
            </div>
            <div class="col-md-2">
                <label class="form-label mb-0 small">Pro Seite</label>
                <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                    <option value="250" selected="@(Model.PageSize == 250)">250</option>
                    <option value="500" selected="@(Model.PageSize == 500)">500</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Suchen</button>
            </div>
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <div class="col-auto">
                    <a asp-action="Index" asp-route-pageSize="@Model.PageSize" class="btn btn-sm btn-outline-secondary">Zurücksetzen</a>
                </div>
            }
            <div class="col-auto ms-auto">
                <span class="text-muted small">@Model.TotalCount Artikel gesamt</span>
            </div>
        </form>
    </div>
</div>

@{
    var attrDefs = Model.AttributeDefinitions;
    var attrValues = Model.AttributeValuesByArticle;
    var totalColCount = 6 + attrDefs.Count + 1; // base cols + category + dynamic attrs
}

<div class="table-responsive">
    <table class="table table-striped mb-0 filterable-table" data-server-column-filter="true">
        <thead>
            <tr>
                <th data-filterable data-col-key="article-number">Artikelnummer</th>
                <th data-filterable data-col-key="description">Bezeichnung</th>
                <th data-filterable data-col-key="unit">Einheit</th>
                <th data-filterable data-col-key="article-group">Artikelgruppe</th>
                <th data-filterable data-col-key="category">Kategorie</th>
                @foreach (var def in attrDefs)
                {
                    @* Kein data-filterable: ApplyArticleColumnFilter mappt attr-Spalten nicht — Filter-Input waere tot *@
                    <th data-col-key="attr-@def.Id">@def.Name</th>
                }
                <th data-col-key="created-at">Erstellt am</th>
                <th data-col-key="actions" style="width: 100px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var article in Model.Items)
            {
                attrValues.TryGetValue(article.Id, out var articleAttrs);
                <tr>
                    <td>
                        <strong>@article.ArticleNumber</strong>
                        <a href="http://akevault24.ake.at/AutodeskTC/AKE-VAULT01/explore?search=@article.ArticleNumber&searchContext=0" target="_blank" title="Zeichnung in Vault oeffnen" class="vault-link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z"/>
                                <path d="M4.5 12.5A.5.5 0 0 1 5 12h3a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m0-2A.5.5 0 0 1 5 10h6a.5.5 0 0 1 0 1H5a.5.5 0 0 1-.5-.5m1.639-3.708 1.33.886 1.854-1.855a.25.25 0 0 1 .289-.047l1.888.974V7.5a.5.5 0 0 1-.5.5H5a.5.5 0 0 1-.5-.5V7s1.54-1.274 1.639-1.208M6.25 6a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5"/>
                            </svg>
                        </a>
                    </td>
                    <td>@article.Description</td>
                    <td>@article.Unit</td>
                    <td>@article.ArticleGroup</td>
                    <td>@(article.ArticleCategory?.Name ?? "")</td>
                    @foreach (var def in attrDefs)
                    {
                        var val = articleAttrs?.FirstOrDefault(v => v.ArticleAttributeDefinitionId == def.Id);
                        <td>
                            @if (val != null)
                            {
                                if (def.AttributeType == IdealAkeWms.Models.AttributeType.Boolean)
                                {
                                    @(val.BooleanValue == true ? "Ja" : "Nein")
                                }
                                else
                                {
                                    @(val.SelectedOption?.Value ?? "")
                                }
                            }
                        </td>
                    }
                    <td>@article.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (canEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@article.Id" class="btn btn-sm btn-secondary">Bearbeiten</a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="@totalColCount" class="text-center text-muted py-4">Keine Artikel vorhanden.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<partial name="_Pagination" model="Model.Pagination" />


@section Scripts {
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
}
