@model PrintPickingViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <title>Kommissionierliste - FA @Model.OrderNumber</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            color: #000;
            background: #fff;
            padding: 20px;
        }

        .screen-controls {
            padding: 15px;
            text-align: center;
            background: #053153;
            color: #fff;
            margin: -20px -20px 20px -20px;
        }

        .screen-controls button {
            background: #fff;
            color: #053153;
            border: none;
            padding: 8px 24px;
            font-size: 16px;
            cursor: pointer;
            border-radius: 4px;
            margin: 0 5px;
        }

        .header-info {
            margin-bottom: 20px;
            border-bottom: 2px solid #053153;
            padding-bottom: 10px;
        }

        .header-info h1 {
            font-size: 20px;
            color: #053153;
        }

        .header-info p {
            margin-top: 4px;
            font-size: 14px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th {
            background: #053153;
            color: #fff;
            padding: 6px 8px;
            text-align: left;
            font-weight: 600;
        }

        td {
            padding: 5px 8px;
            border-bottom: 1px solid #ddd;
        }

        tr:nth-child(even) {
            background: #f5f5f5;
        }

        .text-end {
            text-align: right;
        }

        .footer-info {
            margin-top: 20px;
            font-size: 12px;
            color: #666;
        }

        @@media print {
            .screen-controls {
                display: none !important;
            }

            body {
                padding: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="screen-controls">
        <button onclick="window.print()">Drucken</button>
        <button onclick="window.close()">Schließen</button>
    </div>

    <div class="header-info">
        <h1>Kommissionierliste</h1>
        <p><strong>Fertigungsauftrag:</strong> @Model.OrderNumber</p>
        @if (!string.IsNullOrEmpty(Model.ArticleNumber))
        {
            <p><strong>Artikel:</strong> @Model.ArticleNumber - @Model.Description1</p>
        }
        @if (!string.IsNullOrEmpty(Model.PickedBy))
        {
            <p><strong>Kommissioniert von:</strong> @Model.PickedBy</p>
        }
        <p><strong>Datum:</strong> @DateTime.Now.ToString("dd.MM.yyyy HH:mm")</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Artikelnummer</th>
                <th>Bezeichnung</th>
                <th class="text-end">Menge</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><strong>@item.Artikelnummer</strong></td>
                    <td>@item.Bezeichnung1</td>
                    <td class="text-end">@item.Menge.ToString("N3")</td>
                </tr>
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="3" style="text-align: center; padding: 20px; color: #999;">Keine gepickten Artikel vorhanden.</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="footer-info">
        @Model.Items.Count Positionen | IDEAL-AKE WMS
    </div>
</body>
</html>
