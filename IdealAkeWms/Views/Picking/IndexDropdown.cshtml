@{
    ViewData["Title"] = "Kommissionierung";
}

<h2 class="page-header">Kommissionierung</h2>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card">
            <div class="card-header" style="background-color: var(--ake-secondary);">
                Fertigungsauftrag auswählen
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Fertigungsauftrag suchen und Stückliste zur Kommissionierung öffnen.</p>
                <div class="mb-3">
                    <label class="form-label">Fertigungsauftrag</label>
                    <select class="form-select select2-productionorder" id="ProductionOrderId">
                        <option></option>
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_Select2ProductionOrderPartial" />
}
