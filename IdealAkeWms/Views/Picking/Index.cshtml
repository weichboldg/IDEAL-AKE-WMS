@model PickingListViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Kommissionierung";
}

<h2 class="page-header">Kommissionierung</h2>

@if (Model.PickerAssignmentEnabled)
{
    <div class="mb-3">
        <div class="form-check">
            <input type="checkbox" class="form-check-input" id="showAllOrders"
                   @(Model.ShowAllOrders ? "checked" : "")
                   onchange="window.location.href='@Url.Action("Index")?showAll=' + this.checked" />
            <label class="form-check-label" for="showAllOrders">Alle Kommissionierauftraege anzeigen</label>
        </div>
    </div>
}

@if (!Model.Items.Any())
{
    <div class="alert alert-info">
        @if (Model.PickerAssignmentEnabled && !Model.ShowAllOrders)
        {
            <text>Aktuell sind keine Auftraege fuer Sie zur Kommissionierung freigegeben.</text>
        }
        else
        {
            <text>Aktuell sind keine Auftraege zur Kommissionierung freigegeben.</text>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover mb-0 filterable-table" data-view-key="Picking">
            <thead>
                <tr>
                    <th style="width: 60px;" data-filterable data-col-key="priority">Prio</th>
                    <th data-filterable data-col-key="order-number">FA Nr.</th>
                    <th data-filterable data-col-key="article-number">Artikelnummer</th>
                    <th data-filterable data-col-key="description">Bezeichnung</th>
                    <th data-filterable data-col-key="customer">Kunde</th>
                    <th class="text-end" style="width: 55px;" data-col-key="quantity">Stk.</th>
                    <th data-filterable data-col-key="picking-date" data-date-filter>Komm.-Termin</th>
                    <th data-filterable data-col-key="status">Status</th>
                    @if (Model.PickerAssignmentEnabled)
                    {
                        <th data-filterable data-col-key="picker">Kommissionierer</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var statusBadge = item.PickingStatus switch
                    {
                        "abgeschlossen" => "bg-success",
                        "teilkommissioniert" => "bg-info text-dark",
                        "in Kommissionierung" => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                    var statusText = string.IsNullOrEmpty(item.PickingStatus) ? "Offen" : item.PickingStatus;
                    var kwStr = item.KommissionierTermin.HasValue
                        ? $"{item.KommissionierTermin.Value:dd.MM.yyyy} KW{ISOWeek.GetWeekOfYear(item.KommissionierTermin.Value)}"
                        : "";

                    <tr class="clickable-row" data-href="@Url.Action("Bom", new { id = item.Id })" style="cursor: pointer;">
                        <td><strong>@(item.PickingPriority?.ToString() ?? "-")</strong></td>
                        <td><strong>@item.OrderNumber</strong></td>
                        <td>@item.ArticleNumber</td>
                        <td>@item.Description1</td>
                        <td>@item.Customer</td>
                        <td class="text-end">@item.Quantity.ToString("N0")</td>
                        <td>@kwStr</td>
                        <td><span class="badge @statusBadge">@statusText</span></td>
                        @if (Model.PickerAssignmentEnabled)
                        {
                            <td>@item.AssignedPickerName</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model="Model.Pagination" />
}

<script type="application/json" id="view-config">
{ "viewKey": "Picking", "supportsReorder": true, "supportsSortDefault": true }
</script>
<script type="application/json" id="column-config">
[
    { "key": "priority", "label": "Prio", "locked": false, "defaultWidth": 60 },
    { "key": "order-number", "label": "FA Nr.", "locked": true, "defaultWidth": null },
    { "key": "article-number", "label": "Artikelnummer", "locked": false, "defaultWidth": null },
    { "key": "description", "label": "Bezeichnung", "locked": false, "defaultWidth": null },
    { "key": "customer", "label": "Kunde", "locked": false, "defaultWidth": null },
    { "key": "quantity", "label": "Stk.", "locked": false, "defaultWidth": 55 },
    { "key": "picking-date", "label": "Komm.-Termin", "locked": false, "defaultWidth": null },
    { "key": "status", "label": "Status", "locked": false, "defaultWidth": null }
    @if (Model.PickerAssignmentEnabled) { <text>,{ "key": "picker", "label": "Kommissionierer", "locked": false, "defaultWidth": null }</text> }
]
</script>

@section Scripts {
    <script src="~/js/column-preferences.js" asp-append-version="true"></script>
    <script src="~/js/table-filter.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll('.clickable-row').forEach(function (row) {
            row.addEventListener('click', function () {
                window.location.href = this.getAttribute('data-href');
            });
        });
    </script>
}
